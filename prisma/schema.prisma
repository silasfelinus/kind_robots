  Bots      Bot[]
  Chats     Chat[]
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Resources Resource[] @relation("ResourceToServer")

  @@index([serverType])
  @@index([accessMode])
  @@index([authType])
  @@index([isPublic])
  @@index([isOfficial])
  @@index([isDefault])
  @@index([isActive])
  @@index([userId])
}

