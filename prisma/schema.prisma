// ── Challenge Center (challenge-center project) ─────────────────────────────────
// Agent-vs-agent benchmark arena. Challenges are issued, registered agent Bots
// submit artifacts, users judge via the existing Reaction system
// (reactionCategory: CHALLENGE_SUBMISSION), and leaderboards aggregate net scores.

enum ChallengeType {
  ART
  TEXT
  CHARACTER
  SCENARIO
  REASONING
}

enum ChallengeStatus {
  OPEN
  JUDGING
  CLOSED
}

enum ChallengeSubmissionStatus {
  PENDING
  READY
  DISQUALIFIED
}

model Challenge {
  id            Int                   @id @default(autoincrement())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime?             @default(now()) @updatedAt
  slug          String                @unique @db.VarChar(255)
  title         String                @db.VarChar(764)
  challengeType ChallengeType
  difficulty    Int                   @default(1)
  promptText    String                @db.Text
  judgeNotes    String?               @db.Text
  status        ChallengeStatus       @default(OPEN)
  isMature      Boolean               @default(false)
  userId        Int                   @default(10)
  User          User                  @relation(fields: [userId], references: [id])
  Submissions   ChallengeSubmission[]

  @@index([userId], map: "Challenge_userId_fkey")
  @@index([status])
  @@index([challengeType])
}

model ChallengeSubmission {
  id          Int                       @id @default(autoincrement())
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime?                 @default(now()) @updatedAt
  challengeId Int
  botId       Int
  agentModel  String?                   @db.VarChar(256)
  outputText  String?                   @db.Text
  artImageId  Int?
  characterId Int?
  scenarioId  Int?
  status      ChallengeSubmissionStatus @default(READY)
  Challenge   Challenge                 @relation(fields: [challengeId], references: [id])
  Bot         Bot                       @relation(fields: [botId], references: [id])
  ArtImage    ArtImage?                 @relation(fields: [artImageId], references: [id])
  Character   Character?                @relation(fields: [characterId], references: [id])
  Scenario    Scenario?                 @relation(fields: [scenarioId], references: [id])
  Reactions   Reaction[]

  // One submission per agent per challenge.
  @@unique([challengeId, botId])
  @@index([botId], map: "ChallengeSubmission_botId_fkey")
  @@index([artImageId], map: "ChallengeSubmission_artImageId_fkey")
  @@index([characterId], map: "ChallengeSubmission_characterId_fkey")
  @@index([scenarioId], map: "ChallengeSubmission_scenarioId_fkey")
}

// ── Da Vinci (da-vinci project) ──────────────────────────────────────────────────
// Life-simulation runs: a seeded playthrough (LifeRun) advances by chapters of
// choices (LifeChoice) that move stats (LifeStat), collects generated art along
// the way (LifeRunArt), and resolves to an ending (LifeEnding) with achievements
// (LifeAchievement / LifeAchievementUnlock). Piggybacks on the existing art,
// milestone, chat, and user systems.

enum LifeRunStatus {
  ACTIVE
  COMPLETE
  ABANDONED
}

enum LifeVictoryType {
  VICTORY
  FAILURE
  MIXED
  SECRET
}

enum LifeArtSceneType {
  MOMENT
  DREAM
  CHARACTER
  CHOICE
  THRESHOLD
  ENDING
  ICON
  HERO
}

enum LifeAchievementType {
  CHOICE
  CHAPTER
  STAT_THRESHOLD
  ENDING
  SECRET
  FAILURE
  VICTORY
  COLLECTION
}

model LifeRun {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  userId Int
  title  String        @db.VarChar(255)
  status LifeRunStatus @default(ACTIVE)
  seed   String        @db.VarChar(255)

  protagonistName String? @db.VarChar(255)
  currentAge      Int?
  currentChapter  Int     @default(1)
  genre           String? @db.VarChar(255)

  dreamId         Int?
  characterId     Int?
  botId           Int?
  artCollectionId Int?
  endingId        Int?

  outcomeKey    String? @db.VarChar(16)
  summary       String? @db.Text
  statsSnapshot Json?

  User          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  Dream         Dream?         @relation(fields: [dreamId], references: [id], onDelete: SetNull)
  Character     Character?     @relation(fields: [characterId], references: [id], onDelete: SetNull)
  Bot           Bot?           @relation(fields: [botId], references: [id], onDelete: SetNull)
  ArtCollection ArtCollection? @relation(fields: [artCollectionId], references: [id], onDelete: SetNull)
  Ending        LifeEnding?    @relation(fields: [endingId], references: [id], onDelete: SetNull)

  Choices LifeChoice[]
  Stats   LifeStat[]
  Art     LifeRunArt[]
  Unlocks LifeAchievementUnlock[]

  @@index([userId])
  @@index([status])
  @@index([dreamId])
  @@index([characterId])
  @@index([botId])
  @@index([artCollectionId])
  @@index([endingId])
  @@index([outcomeKey])
}

model LifeChoice {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  lifeRunId  Int
  chatId     Int?
  chapter    Int
  prompt     String  @db.Text
  choiceText String  @db.Text
  resultText String? @db.Text
  effects    Json?

  LifeRun LifeRun @relation(fields: [lifeRunId], references: [id], onDelete: Cascade)
  Chat    Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)

  @@index([lifeRunId])
  @@index([chatId])
  @@index([chapter])
}

model LifeStat {
  id        Int    @id @default(autoincrement())
  lifeRunId Int
  key       String @db.VarChar(64)
  value     Int    @default(0)

  LifeRun LifeRun @relation(fields: [lifeRunId], references: [id], onDelete: Cascade)

  @@unique([lifeRunId, key])
  @@index([key])
}

model LifeEnding {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  title       String          @db.VarChar(255)
  slug        String          @unique @db.VarChar(255)
  outcomeKey  String          @unique @db.VarChar(16)
  summary     String          @db.Text
  victoryType LifeVictoryType @default(MIXED)

  icon           String? @db.VarChar(764)
  heroImage      String? @db.VarChar(764)
  iconArtImageId Int?
  heroArtImageId Int?
  milestoneId    Int?

  artPrompt String? @db.Text
  metadata  Json?
  isActive  Boolean @default(true)

  IconArtImage ArtImage?  @relation("LifeEndingIconArtImage", fields: [iconArtImageId], references: [id], onDelete: SetNull)
  HeroArtImage ArtImage?  @relation("LifeEndingHeroArtImage", fields: [heroArtImageId], references: [id], onDelete: SetNull)
  Milestone    Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  Runs         LifeRun[]
  Achievements LifeAchievement[]

  @@index([victoryType])
  @@index([milestoneId])
  @@index([iconArtImageId])
  @@index([heroArtImageId])
  @@index([isActive])
}

model LifeAchievement {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  title           String              @db.VarChar(255)
  slug            String              @unique @db.VarChar(255)
  achievementType LifeAchievementType
  conditionKey    String?             @db.VarChar(255)
  description     String?             @db.Text

  icon        String? @db.VarChar(764)
  imagePath   String? @db.VarChar(764)
  artImageId  Int?
  milestoneId Int?
  endingId    Int?

  metadata Json?
  isActive Boolean @default(true)

  ArtImage  ArtImage?               @relation(fields: [artImageId], references: [id], onDelete: SetNull)
  Milestone Milestone?              @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  Ending    LifeEnding?             @relation(fields: [endingId], references: [id], onDelete: SetNull)
  Unlocks   LifeAchievementUnlock[]

  @@index([achievementType])
  @@index([conditionKey])
  @@index([artImageId])
  @@index([milestoneId])
  @@index([endingId])
  @@index([isActive])
}

model LifeAchievementUnlock {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId            Int
  lifeRunId         Int?
  achievementId     Int
  milestoneRecordId Int?

  data Json?

  User            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  LifeRun         LifeRun?         @relation(fields: [lifeRunId], references: [id], onDelete: Cascade)
  Achievement     LifeAchievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  MilestoneRecord MilestoneRecord? @relation(fields: [milestoneRecordId], references: [id], onDelete: SetNull)

  @@unique([userId, achievementId, lifeRunId])
  @@index([userId])
  @@index([lifeRunId])
  @@index([achievementId])
  @@index([milestoneRecordId])
}

model LifeRunArt {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  lifeRunId  Int
  artImageId Int
  chapter    Int?
  sceneType  LifeArtSceneType @default(MOMENT)
  prompt     String           @db.Text

  LifeRun  LifeRun  @relation(fields: [lifeRunId], references: [id], onDelete: Cascade)
  ArtImage ArtImage @relation(fields: [artImageId], references: [id], onDelete: Cascade)

  @@index([lifeRunId])
  @@index([artImageId])
  @@index([sceneType])
  @@index([chapter])
}
