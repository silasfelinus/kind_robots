/// This should also be used if a user wants to add a custom art or text checkpoints
model Resource {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @default(now()) @updatedAt
  name            String          @unique(map: "Resource_id_key", length: 200) @db.VarChar(764)
  customLabel     String?         @db.VarChar(764)
  MediaPath       String?         @db.VarChar(764)
  customUrl       String?         @db.VarChar(764)
  civitaiUrl      String?         @db.VarChar(764)
  huggingUrl      String?         @db.VarChar(764)
  localPath       String?         @db.VarChar(764)
  description     String?         @db.Text
  isMature        Boolean         @default(false)
  resourceType    ResourceType    @default(EMBEDDING)
  userId          Int?            @default(1)
  artImageId      Int?
  generation      String?
  supportedServer SupportedServer @default(SDXL)
  isPublic        Boolean         @default(false)
  isActive        Boolean         @default(true)
  artPrompt       String?         @db.Text
  imagePath       String?
  slug            String?         @unique @db.VarChar(255)
  ArtImages       ArtImage[]      @relation("ArtImageCheckpointResource")
  Reactions       Reaction[]
  ArtImage        ArtImage?       @relation("ResourcePreviewImage", fields: [artImageId], references: [id])
  User            User?           @relation(fields: [userId], references: [id])
  UsedInImages    ArtImage[]      @relation("ArtImageLoraResources")
  Servers         Server[]        @relation("ResourceToServer")

  @@index([userId], map: "Resource_userId_fkey")
  @@index([artImageId], map: "Resource_artImageId_fkey")
}

/// Rewards are skills, items, pets, and other collectibles used in storytelling
/// adventure modules. name/description/flavorText describe what it is; effect is
/// the LLM-facing narrative hook that tells the storytelling engine how the reward
/// behaves when played into a scene.
model Reward {
  id           Int           @id @default(autoincrement())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime?     @default(now()) @updatedAt
  icon         String?       @db.VarChar(256)
  collection   String?       @db.VarChar(764)
  rarity       Rarity        @default(COMMON)
  userId       Int?          @default(1)
  artImageId   Int?
  imagePath    String?       @db.VarChar(764)
  isMature     Boolean       @default(false)
  isPublic     Boolean       @default(true)
  isActive     Boolean       @default(true)
  artPrompt    String?       @db.Text
  rewardType   RewardType    @default(ITEM)
  description  String?       @db.Text
  effect       String?       @db.Text
  flavorText   String?       @db.VarChar(512)
  name         String        @db.VarChar(256)
  slug         String?       @unique @db.VarChar(256)
  Compositions Composition[]
  Reactions    Reaction[]
  ArtImage     ArtImage?     @relation(fields: [artImageId], references: [id])
  User         User?         @relation(fields: [userId], references: [id])
  Characters   Character[]   @relation("CharacterToReward")
  Dreams       Dream[]       @relation("DreamToReward")

  @@index([userId], map: "Reward_userId_fkey")
  @@index([rewardType])
  @@index([rarity])
  @@index([slug])
  @@index([artImageId], map: "Reward_artImageId_fkey")
}

/// Scenarios are meant to be chatroom settings or storytelling scenarios that incorporate other elements like Character, prompt, ArtImage, etc. A user is given options to continue the scenario with a skill check, inventory item, Reward, or custom prompt. The idea is to generate a story through the back and forth exchange.
model Scenario {
  id                   Int                   @id @default(autoincrement())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime?             @default(now()) @updatedAt
  title                String
  description          String                @db.Text
  intros               String                @db.Text
  userId               Int?
  artImageId           Int?
  imagePath            String?
  locations            String?               @db.Text
  artPrompt            String?               @db.Text
  genres               String?
  inspirations         String?               @db.Text
  isMature             Boolean               @default(false)
  isPublic             Boolean               @default(true)
  isActive             Boolean               @default(true)
  difficulty           Int?
  group                String?
  secretNotes          String?
  tier                 String?
  cast                 String?               @db.LongText
  outputType           ScenarioOutputType    @default(STORY)
  slug                 String?               @unique @db.VarChar(255)
  ChallengeSubmissions ChallengeSubmission[]
  Compositions         Composition[]
  Reactions            Reaction[]
  ArtImage             ArtImage?             @relation(fields: [artImageId], references: [id])
  User                 User?                 @relation(fields: [userId], references: [id])
  FacetLinks           ScenarioFacet[]
  Characters           Character[]           @relation("CharacterToScenario")
  Dreams               Dream[]               @relation("DreamToScenario")

  @@index([artImageId], map: "Scenario_artImageId_fkey")
  @@index([userId], map: "Scenario_userId_fkey")
}

model Server {
  id            Int                 @id @default(autoincrement())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  title         String
  label         String?
  description   String?             @db.Text
  serverType    ServerType          @default(CUSTOM)
  category      String?
  baseUrl       String?             @db.VarChar(764)
  endpointPath  String?             @db.VarChar(512)
  healthPath    String?             @db.VarChar(512)
  userId        Int?
  isPublic      Boolean             @default(false)
  isOfficial    Boolean             @default(false)
  isDefault     Boolean             @default(false)
  isActive      Boolean             @default(true)
  isEditable    Boolean             @default(true)
  apiKeyName    String?             @db.VarChar(255)
  apiLink       String?             @db.VarChar(764)
  model         String?             @db.VarChar(255)
  apiKey        String?             @db.Text
  designer      String?             @db.VarChar(255)
  version       String?             @db.VarChar(255)
  notes         String?             @db.Text
  sortOrder     Int                 @default(0)
  lastCheckedAt DateTime?
  lastStatus    ServerStatus        @default(UNKNOWN)
  accessMode    ServerAccessMode    @default(BROWSER)
  isMature      Boolean             @default(false)
  artPrompt     String?             @db.Text
  authType      ServerAuthType      @default(NONE)
  ArtImages     ArtImage[]          @relation("ArtImageGeneratorServer")
  Bots          Bot[]
  Chats         Chat[]
  Prompts       Prompt[]            @relation("PromptServer")
  user          User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  HealthChecks  ServerHealthCheck[]
  Resources     Resource[]          @relation("ResourceToServer")

  @@index([serverType])
  @@index([accessMode])
  @@index([authType])
  @@index([isPublic])
  @@index([isOfficial])
  @@index([isDefault])
  @@index([isActive])
  @@index([userId])
}

/// Time-series health/uptime samples for a Server. The point-in-time
/// `Server.lastStatus`/`lastCheckedAt` are overwritten on every check; this
/// table keeps history so the ArtJob dashboard can show ComfyUI/SD uptime over
/// time. Rows are written by the relay heartbeat (/api/server/heartbeat) and by
/// the browser/server health checks (/api/server/health/[id]).
model ServerHealthCheck {
  id        Int          @id @default(autoincrement())
  createdAt DateTime     @default(now())
  serverId  Int
  checkedAt DateTime     @default(now())
  status    ServerStatus @default(UNKNOWN)
  ok        Boolean      @default(false)
  latencyMs Int?
  source    String       @default("server") @db.VarChar(32)
  note      String?      @db.Text
  Server    Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, checkedAt])
  @@index([checkedAt])
}

/// Smart Icons are used internally to generate the user's icon array. They can create custom icons that are links to pages or commands
model SmartIcon {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  title       String    @db.VarChar(255)
  type        String    @db.VarChar(255)
  designer    String?   @db.VarChar(255)
  userId      Int?      @default(10)
  icon        String?   @db.VarChar(255)
  label       String?   @db.VarChar(255)
  link        String?   @db.VarChar(512)
  component   String?   @db.VarChar(255)
  isPublic    Boolean   @default(true)
  description String?   @db.VarChar(255)
  category    String?   @db.VarChar(255)
  modelType   String?   @db.VarChar(255)
  isMature    Boolean   @default(false)
  User        User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "SmartIcon_userId_fkey")
}

model SocialPost {
  id          Int            @id @default(autoincrement())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  designer    String?        @db.VarChar(256)
  title       String         @db.VarChar(255)
  body        String         @db.Text
  mediaUrls   String?        @db.LongText
  status      PostStatus     @default(DRAFT)
  sourceType  String?
  sourceId    Int?
  scheduledAt DateTime?
  isPublic    Boolean        @default(false)
  userId      Int?
  isActive    Boolean        @default(true)
  isMature    Boolean        @default(false)
  audience    PostAudience   @default(SOCIAL)
  User        User?          @relation(fields: [userId], references: [id])
