### Seed: All Conductor Projects as one batch
@base = https://kind-robots.vercel.app/api
@admintoken = {{$dotenv ADMIN_TOKEN}}
@imgbase = https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images

POST {{base}}/dreams/batch
Content-Type: application/json
x-admin-token: {{admintoken}}

{
  "dreams": [
    {
      "title": "Kind Robots",
      "slug": "kind-robots",
      "dreamType": "PROJECT",
      "projectStatus": "ACTIVE",
      "description": "The Kind Robots app — a Nuxt 4/Vue 3/TS/Prisma/Pinia/DaisyUI platform for AI-assisted creativity. Covers art generation, character creation, scenario building, and agent-driven workflows.",
      "pitch": "Build app-owned logic here; consume shared backend as read-only. Do not reimplement the shared backend.",
      "flavorText": "Where AI and humans make things together.",
      "imagePath": "{{imgbase}}/kind-robots-icon.webp",
      "cardPath": "{{imgbase}}/kind-robots-card.webp",
      "heroPath": "{{imgbase}}/kind-robots-hero.webp",
      "icon": "kind-icon:robot",
      "repoUrl": "https://github.com/silasfelinus/kind_robots",
      "liveUrl": "https://kind-robots.vercel.app",
      "isPublic": true,
      "isMature": false,
      "isActive": true,
      "allowReviews": false
    },
    {
      "title": "Humboldt Scoop",
      "slug": "humboldt-scoop",
      "dreamType": "PROJECT",
      "projectStatus": "ACTIVE",
      "description": "The existing Humboldt Scoop website — the first real test of the agent loop. A local business site for a poop-scoop service in Humboldt County.",
      "pitch": "First real test of the agent loop. Do NOT deploy or touch DNS unattended.",
      "flavorText": "Keeping Humboldt clean, one yard at a time.",
