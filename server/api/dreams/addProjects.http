### Seed: Conductor Projects as PROJECT-type Dreams
### Run these once against your local or prod DB.
### Images are served from the conductor GitHub repo.
### Auth: set ADMIN_TOKEN in your .env (or .env.local)

@base = https://kind-robots.vercel.app/api
@admintoken = {{$dotenv ADMIN_TOKEN}}

# ─── Image base URL ────────────────────────────────────────────────────────────
# All project images live in:
# https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/

### ── 1. kind-robots ──────────────────────────────────────────────────────────
POST {{base}}/dreams
Content-Type: application/json
Authorization: Bearer {{admintoken}}

{
  "title": "Kind Robots",
  "slug": "kind-robots",
  "dreamType": "PROJECT",
  "projectStatus": "ACTIVE",
  "description": "The Kind Robots app — a Nuxt 4/Vue 3/TS/Prisma/Pinia/DaisyUI platform for AI-assisted creativity. Covers art generation, character creation, scenario building, and agent-driven workflows.",
  "pitch": "Build app-owned logic here; consume shared backend as read-only. Do not reimplement the shared backend.",
  "flavorText": "Where AI and humans make things together.",
  "imagePath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/kind-robots-icon.webp",
  "cardPath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/kind-robots-card.webp",
  "heroPath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/kind-robots-hero.webp",
  "icon": "kind-icon:robot",
  "repoUrl": "https://github.com/silasfelinus/kind_robots",
  "liveUrl": "https://kind-robots.vercel.app",
  "isPublic": true,
  "isMature": false,
  "isActive": true,
  "allowReviews": false
}

