### ── 4. approval-portal ──────────────────────────────────────────────────────
POST {{base}}/dreams
Content-Type: application/json
Authorization: Bearer {{admintoken}}

{
  "title": "Approval Portal",
  "slug": "approval-portal",
  "dreamType": "PROJECT",
  "projectStatus": "ACTIVE",
  "description": "A portal for Silas to review AI agent work: pick pitches, validate upgrades, confirm updates, and roll back changes. The repo stays source of truth — the portal reads roadmaps/pitches/git and writes decisions as commits/PRs.",
  "pitch": "Core principle: the repo is always the source of truth. The portal is a read/write UI on top of git.",
  "flavorText": "Where the human stays in control.",
  "imagePath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/approval-portal-icon.webp",
  "cardPath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/approval-portal-card.webp",
  "heroPath": "https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images/approval-portal-hero.webp",
  "icon": "kind-icon:check",
  "repoUrl": "https://github.com/silasfelinus/conductor",
  "isPublic": true,
  "isMature": false,
  "isActive": true,
  "allowReviews": false
}

