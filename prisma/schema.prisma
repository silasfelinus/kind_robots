generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// ArtImage is meant to be grabbed as needed, to avoid data bloat. The primary element is imageData
model ArtImage {
  id                   Int                   @id @default(autoincrement())
  imageData            String?               @db.LongText
  createdAt            DateTime              @default(now())
  updatedAt            DateTime?             @default(now()) @updatedAt
  userId               Int?                  @default(10)
  fileName             String?               @db.VarChar(764)
  fileType             String                @default("png")
  cfg                  Int?                  @default(3)
  cfgHalf              Boolean?              @default(false)
  checkpoint           String?               @db.VarChar(256)
  checkpointResourceId Int?
  designer             String?               @db.VarChar(764)
  genres               String?
  imagePath            String?
  isMature             Boolean?              @default(false)
  isPublic             Boolean?              @default(true)
  negativePrompt       String?               @db.Text
  path                 String?               @db.VarChar(764)
  promptString         String?               @db.Text
  sampler              String?               @db.VarChar(764)
  seed                 Int?                  @default(-1)
  serverId             Int?
  serverName           String?               @db.VarChar(256)
  serverUrl            String?               @db.VarChar(764)
  steps                Int?
  isActive             Boolean?              @default(true)
  artPrompt            String?               @db.Text
  cardData             String?               @db.Text
  cardPath             String?               @db.Text
  heroData             String?               @db.Text
  heroPath             String?               @db.Text
  iconData             String?               @db.Text
  iconPath             String?               @db.Text
  thumbnailData        String?               @db.Text
  thumbnailPath        String?               @db.Text
  Achievements         Achievement[]
  CheckpointResource   Resource?             @relation("ArtImageCheckpointResource", fields: [checkpointResourceId], references: [id])
  Server               Server?               @relation("ArtImageGeneratorServer", fields: [serverId], references: [id])
  User                 User?                 @relation("ArtImageCreator", fields: [userId], references: [id])
  Bots                 Bot[]
  ChallengeSubmissions ChallengeSubmission[]
  Characters           Character[]
  Chats                Chat[]
  Components           Component[]
  Compositions         Composition?
  Contenders           Contender[]
  DreamsPrimary        Dream[]               @relation("DreamPrimaryArtImage")
  ExpressionMedia      ExpressionMedia?
  FacetsPrimary        Facet[]               @relation("FacetPrimaryArtImage")
  FacetLinks           FacetArtImage[]
  LifeAchievements     LifeAchievement[]
  LifeEndingHeroes     LifeEnding[]          @relation("LifeEndingHeroArtImage")
  LifeEndingIcons      LifeEnding[]          @relation("LifeEndingIconArtImage")
  LifeRunArt           LifeRunArt[]
  PitchSheets          PitchSheet[]
  ProjectsPrimary      Project[]             @relation("ProjectPrimaryArtImage")
  ProjectLinks         ProjectArtImage[]
  Prompts              Prompt[]
  Reactions            Reaction[]
  Resources            Resource[]            @relation("ResourcePreviewImage")
  Rewards              Reward[]
  Scenarios            Scenario[]
  UserProfiles         User[]                @relation("UserProfileImage")
  ArtCollections       ArtCollection[]       @relation("ArtCollectionToArtImage")
  LoraResources        Resource[]            @relation("ArtImageLoraResources")
  Dreams               Dream[]               @relation("DreamToArtImage")

  @@index([userId], map: "ArtImage_userId_fkey")
  @@index([checkpointResourceId], map: "ArtImage_checkpointResourceId_fkey")
  @@index([serverId], map: "ArtImage_serverId_fkey")
}

model ArtCollection {
  id              Int                    @id @default(autoincrement())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime?              @default(now()) @updatedAt
  userId          Int?                   @default(10)
  label           String?
  isMature        Boolean                @default(false)
  isPublic        Boolean                @default(true)
  description     String?                @db.Text
  username        String?
  isActive        Boolean                @default(true)
  artPrompt       String?                @db.Text
  imagePath       String?                @db.VarChar(764)
  slug            String?                @unique @db.VarChar(255)
  parentFolder    String?                @db.VarChar(512)
  User            User?                  @relation(fields: [userId], references: [id])
  DreamsPrimary   Dream[]                @relation("DreamPrimaryArtCollection")
  FacetsPrimary   Facet[]                @relation("FacetPrimaryArtCollection")
  FacetLinks      FacetArtCollection[]
  LifeRuns        LifeRun[]
  ProjectsPrimary Project[]              @relation("ProjectPrimaryArtCollection")
  ProjectLinks    ProjectArtCollection[]
  Reactions       Reaction[]
  ArtImages       ArtImage[]             @relation("ArtCollectionToArtImage")
  Dreams          Dream[]                @relation("DreamToArtCollection")

  @@index([userId], map: "ArtCollection_userId_fkey")
}

model Bot {
  id                   Int                    @id @default(autoincrement())
  createdAt            DateTime               @default(now())
  updatedAt            DateTime?              @default(now()) @updatedAt
  BotType              String                 @db.VarChar(764)
  name                 String                 @db.VarChar(256)
  subtitle             String?                @db.VarChar(764)
  description          String?                @db.VarChar(764)
  avatarImage          String?                @db.VarChar(764)
  botIntro             String                 @db.VarChar(3000)
  userIntro            String                 @db.VarChar(764)
  prompt               String                 @db.VarChar(764)
  trainingPath         String?                @db.VarChar(764)
  theme                String?                @db.VarChar(764)
  personality          String?                @db.VarChar(764)
  modules              String?                @db.VarChar(764)
  sampleResponse       String?                @db.VarChar(764)
  tagline              String?                @db.VarChar(764)
  isPublic             Boolean                @default(true)
  underConstruction    Boolean                @default(false)
  canDelete            Boolean                @default(false)
  userId               Int?                   @default(1)
  designer             String                 @default("silasfelinus")
  serverId             Int?
  serverName           String?                @db.VarChar(256)
  artImageId           Int?
  isMature             Boolean                @default(false)
  isActive             Boolean                @default(true)
  artPrompt            String?                @db.Text
  imagePath            String?                @db.VarChar(764)
  forgeIntro           String?                @db.Text
  narrativeVoice       String?                @db.Text
  slug                 String?                @unique @db.VarChar(255)
  chatBorderImage      String?                @db.VarChar(764)
  ArtImage             ArtImage?              @relation(fields: [artImageId], references: [id])
  Server               Server?                @relation(fields: [serverId], references: [id])
  User                 User?                  @relation(fields: [userId], references: [id])
  ChallengeSubmissions ChallengeSubmission[]
  Chats                Chat[]
  NarratedDreams       Dream[]                @relation("DreamNarrator")
  ExpressionMedia      ExpressionMedia[]
  ExpressionTransition ExpressionTransition[]
  LifeRuns             LifeRun[]
  NarratorThreads      NarratorThread[]
  ManagedProjects      Project[]              @relation("ProjectManager")
  Prompts              Prompt[]
  Reactions            Reaction[]
  Dreams               Dream[]                @relation("BotToDream")

  @@index([userId], map: "Bot_userId_fkey")
  @@index([serverId], map: "Bot_serverId_fkey")
  @@index([artImageId], map: "Bot_artImageId_fkey")
}

model Character {
  id                   Int                    @id @default(autoincrement())
  createdAt            DateTime               @default(now())
  updatedAt            DateTime?              @default(now()) @updatedAt
  name                 String                 @db.VarChar(256)
  achievements         String?                @db.VarChar(764)
  alignment            String?                @db.VarChar(256)
  experience           Int                    @default(0)
  level                Int                    @default(1)
  class                String?                @db.VarChar(764)
  species              String?                @db.VarChar(764)
  backstory            String?                @db.Text
  drive                String?                @db.VarChar(764)
  quirks               String?                @db.Text
  genre                String?                @db.VarChar(256)
  artImageId           Int?
  isPublic             Boolean                @default(true)
  userId               Int?                   @default(10)
  artPrompt            String?                @db.Text
  honorific            String?                @default("adventurer") @db.VarChar(256)
  imagePath            String?                @db.VarChar(764)
  designer             String?                @db.VarChar(256)
  personality          String?                @db.Text
  isMature             Boolean                @default(false)
  isActive             Boolean                @default(true)
  charm                Rarity                 @default(COMMON)
  empathy              Rarity                 @default(COMMON)
  grace                Rarity                 @default(COMMON)
  luck                 Rarity                 @default(COMMON)
  might                Rarity                 @default(COMMON)
  presentation         String?                @db.VarChar(764)
  role                 String?                @db.VarChar(256)
  title                String?                @db.VarChar(256)
  wits                 Rarity                 @default(COMMON)
  gender               String?                @db.VarChar(256)
  slug                 String?                @unique @db.VarChar(255)
  ChallengeSubmissions ChallengeSubmission[]
  ArtImage             ArtImage?              @relation(fields: [artImageId], references: [id])
  User                 User?                  @relation(fields: [userId], references: [id])
  Chats                Chat[]
  Compositions         Composition[]
  ExpressionMedia      ExpressionMedia[]
  ExpressionTransition ExpressionTransition[]
  LifeRuns             LifeRun[]
  Reactions            Reaction[]
  Dreams               Dream[]                @relation("CharacterToDream")
  Rewards              Reward[]               @relation("CharacterToReward")
  Scenarios            Scenario[]             @relation("CharacterToScenario")

  @@index([userId], map: "Character_userId_fkey")
  @@index([isPublic])
  @@index([isActive])
  @@index([name])
  @@index([artImageId], map: "Character_artImageId_fkey")
}

/// a chat can be between users, user to Bot or Character, on to a Forum or Channel (aka chatroom)
/// originId should always be shared in subsequent messages so we can track the thread via originID and createdAt
/// splitting the chat into a new thread creates a fresh originId
model Chat {
  id              Int          @id @default(autoincrement())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime?    @default(now()) @updatedAt
  type            ChatType
  sender          String       @db.VarChar(255)
  recipient       String?      @db.VarChar(255)
  content         String       @db.Text
  title           String?      @db.VarChar(255)
  isPublic        Boolean      @default(true)
  isFavorite      Boolean      @default(false)
  previousEntryId Int?
  originId        Int?
  userId          Int?
  botId           Int?
  recipientId     Int?
  artImageId      Int?
  promptId        Int?
  botName         String?      @db.VarChar(255)
  channel         String?      @db.VarChar(255)
  botResponse     String?
  characterId     Int?
  isRead          Boolean      @default(false)
  isMature        Boolean      @default(false)
  serverId        Int?
  serverName      String?      @db.VarChar(256)
  dreamId         Int?
  isActive        Boolean      @default(true)
  readAt          DateTime?
  projectId       Int?
  ArtImage        ArtImage?    @relation(fields: [artImageId], references: [id])
  Bot             Bot?         @relation(fields: [botId], references: [id])
  Character       Character?   @relation(fields: [characterId], references: [id])
  Dream           Dream?       @relation(fields: [dreamId], references: [id])
  Project         Project?     @relation(fields: [projectId], references: [id])
  Prompt          Prompt?      @relation(fields: [promptId], references: [id])
  Server          Server?      @relation(fields: [serverId], references: [id])
  User            User?        @relation(fields: [userId], references: [id])
  LifeChoices     LifeChoice[]
  Reactions       Reaction[]

  @@index([serverId], map: "Chat_serverId_fkey")
  @@index([botId], map: "Chat_botId_fkey")
  @@index([characterId], map: "Chat_characterId_fkey")
  @@index([promptId], map: "Chat_promptId_fkey")
  @@index([userId], map: "Chat_userId_fkey")
  @@index([dreamId], map: "Chat_dreamId_fkey")
  @@index([projectId], map: "Chat_projectId_fkey")
  @@index([artImageId], map: "Chat_artImageId_fkey")
  @@index([originId, createdAt])
  @@index([recipientId])
}

/// programmatic blueprints to call one or more art or text servers
model Code {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  userId      Int?     @default(10)
  title       String
  description String?  @db.Text
  icon        String?
  graph       String   @db.LongText
  isPublic    Boolean  @default(false)
  isOfficial  Boolean  @default(false)
  isActive    Boolean  @default(true)
  isMature    Boolean  @default(false)
  User        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isPublic])
  @@index([isOfficial])
  @@index([isActive])
  @@index([isMature])
}

/// Components track all the components we use making kindrobots. it's primary uses are as a museum of developmental attemps, while allowing reactions to allow sifting concepts and allowing the best to rise to attention.
model Component {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime?  @default(now()) @updatedAt
  folderName        String
  componentName     String     @unique
  isWorking         Boolean    @default(true)
  underConstruction Boolean    @default(false)
  isBroken          Boolean    @default(false)
  title             String?
  notes             String?
  artImageId        Int?
  ArtImage          ArtImage?  @relation(fields: [artImageId], references: [id])
  Reactions         Reaction[]

  @@index([artImageId], map: "Component_artImageId_fkey")
}

model Composition {
  id             Int               @id @default(autoincrement())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  title          String            @db.VarChar(255)
  description    String?           @db.VarChar(512)
  label          String?           @db.VarChar(255)
  mode           String            @default("both") @db.VarChar(64)
  isPublic       Boolean           @default(true)
  isMature       Boolean           @default(false)
  isActive       Boolean           @default(true)
  designer       String?           @default("system") @db.VarChar(255)
  characterId    Int?
  dreamId        Int?
  scenarioId     Int?
  rewardId       Int?
  characterBlurb String?           @db.VarChar(512)
  dreamBlurb     String?           @db.VarChar(512)
  scenarioBlurb  String?           @db.VarChar(512)
  rewardBlurb    String?           @db.VarChar(512)
  narrativeText  String?           @db.Text
  artPrompt      String?           @db.Text
  userId         Int?
  artImageId     Int?              @unique
  imagePath      String?           @db.VarChar(764)
  approvedAt     DateTime?
  bountyId       Int?
  manaCharged    Int?
  outputDreamId  Int?              @unique
  status         CompositionStatus @default(DRAFT)
  stepLog        String?           @db.LongText
  userApproved   Boolean           @default(false)
  wishText       String?           @db.Text
  ArtImage       ArtImage?         @relation(fields: [artImageId], references: [id])
  Character      Character?        @relation(fields: [characterId], references: [id])
  Dream          Dream?            @relation(fields: [dreamId], references: [id])
  OutputDream    Dream?            @relation("CompositionOutputDream", fields: [outputDreamId], references: [id])
  Reward         Reward?           @relation(fields: [rewardId], references: [id])
  Scenario       Scenario?         @relation(fields: [scenarioId], references: [id])
  User           User?             @relation(fields: [userId], references: [id])
  Reactions      Reaction[]

  @@index([userId])
  @@index([mode])
  @@index([characterId])
  @@index([dreamId])
  @@index([scenarioId])
  @@index([rewardId])
}

/// A Dream is the canonical "idea/vibe" that governs a generation. It absorbs
/// the old Pitch concept: a single big-picture seed that fuels art assets, text
/// assets, characters, rewards, and collections. Each Dream can own many
/// ArtImages / ArtCollections / Characters / Rewards, while also designating a
/// primary "main choice" for each via the singular FK fields.
model Dream {
  id                Int             @id @default(autoincrement())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime?       @default(now()) @updatedAt
  title             String          @db.VarChar(255)
  slug              String?         @unique @db.VarChar(255)
  description       String?         @db.Text
  userId            Int?            @default(10)
  artImageId        Int?
  artCollectionId   Int?
  isPublic          Boolean         @default(true)
  isMature          Boolean         @default(false)
  isActive          Boolean         @default(true)
  artPrompt         String?         @db.Text
  creationSource    CreationSource  @default(HUMAN)
  designer          String?         @db.VarChar(256)
  dreamType         DreamType       @default(PITCH)
  examples          String?         @db.LongText
  flavorText        String?         @db.VarChar(512)
  highlightImage    String?         @db.VarChar(256)
  icon              String?
  imagePath         String?         @db.Text
  pitch             String?         @db.Text
  allowReviews      Boolean         @default(false)
  cardPath          String?         @db.Text
  heroPath          String?         @db.Text
  narratorId        Int?
  Chats             Chat[]
  Compositions      Composition[]
  SourceComposition Composition?    @relation("CompositionOutputDream")
  ArtCollection     ArtCollection?  @relation("DreamPrimaryArtCollection", fields: [artCollectionId], references: [id])
  ArtImage          ArtImage?       @relation("DreamPrimaryArtImage", fields: [artImageId], references: [id])
  Narrator          Bot?            @relation("DreamNarrator", fields: [narratorId], references: [id])
  User              User?           @relation(fields: [userId], references: [id])
  FacetLinks        DreamFacet[]
  RelationsFrom     DreamRelation[] @relation("DreamRelationFrom")
  RelationsTo       DreamRelation[] @relation("DreamRelationTo")
  LifeRuns          LifeRun[]
  PitchSheet        PitchSheet?
  Reactions         Reaction[]
  Todos             Todo[]
  Bots              Bot[]           @relation("BotToDream")
  Characters        Character[]     @relation("CharacterToDream")
  ArtCollections    ArtCollection[] @relation("DreamToArtCollection")
  ArtImages         ArtImage[]      @relation("DreamToArtImage")
  Rewards           Reward[]        @relation("DreamToReward")
  Scenarios         Scenario[]      @relation("DreamToScenario")

  @@index([artImageId], map: "Dream_artImageId_fkey")
  @@index([userId])
  @@index([dreamType])
  @@index([isPublic])
  @@index([isActive])
  @@index([artCollectionId])
  @@index([narratorId])
}

model DreamRelation {
  id           Int               @id @default(autoincrement())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime?         @default(now()) @updatedAt
  fromDreamId  Int
  toDreamId    Int
  relationType DreamRelationType @default(RELATED)
  note         String?           @db.VarChar(512)
  FromDream    Dream             @relation("DreamRelationFrom", fields: [fromDreamId], references: [id], onDelete: Cascade)
  ToDream      Dream             @relation("DreamRelationTo", fields: [toDreamId], references: [id], onDelete: Cascade)

  @@unique([fromDreamId, toDreamId, relationType])
  @@index([fromDreamId])
  @@index([toDreamId])
  @@index([relationType])
}

/// Projects are implementation records synchronized with Conductor. Creative world
/// infrastructure belongs to Dream; lightweight reusable flavor belongs to Facet.
model Project {
  id                 Int                    @id @default(autoincrement())
  createdAt          DateTime               @default(now())
  updatedAt          DateTime?              @default(now()) @updatedAt
  title              String                 @db.VarChar(255)
  slug               String?                @unique @db.VarChar(255)
  description        String?                @db.Text
  pitch              String?                @db.Text
  flavorText         String?                @db.VarChar(512)
  goal               String?                @db.Text
  status             ProjectStatus          @default(BRAINSTORM)
  priority           ProjectPriority        @default(NORMAL)
  conductorSlug      String?                @unique @db.VarChar(255)
  repoUrl            String?                @db.VarChar(512)
  liveUrl            String?                @db.VarChar(512)
  channelKey         String?                @db.VarChar(255)
  tabKey             String?                @db.VarChar(255)
  lastSyncedAt       DateTime?
  allowReviews       Boolean                @default(false)
  highlightImage     String?                @db.VarChar(256)
  icon               String?
  imagePath          String?                @db.Text
  cardPath           String?                @db.Text
  heroPath           String?                @db.Text
  designer           String?                @db.VarChar(256)
  creationSource     CreationSource         @default(HUMAN)
  userId             Int?                   @default(10)
  managerBotId       Int?
  artImageId         Int?
  artCollectionId    Int?
  isPublic           Boolean                @default(true)
  isMature           Boolean                @default(false)
  isActive           Boolean                @default(true)
  ArtJobs            ArtJob[]
  Chats              Chat[]
  PitchSheet         PitchSheet?
  ArtCollection      ArtCollection?         @relation("ProjectPrimaryArtCollection", fields: [artCollectionId], references: [id])
  ArtImage           ArtImage?              @relation("ProjectPrimaryArtImage", fields: [artImageId], references: [id])
  Manager            Bot?                   @relation("ProjectManager", fields: [managerBotId], references: [id])
  User               User?                  @relation(fields: [userId], references: [id])
  ArtCollectionLinks ProjectArtCollection[]
  ArtImageLinks      ProjectArtImage[]
  Reactions          Reaction[]
  Todos              Todo[]

  @@index([userId])
  @@index([managerBotId])
  @@index([artImageId])
  @@index([artCollectionId])
  @@index([status])
  @@index([priority])
  @@index([channelKey, tabKey])
  @@index([isPublic])
  @@index([isActive])
}

/// Facets are lightweight reusable creative building blocks: genres, animals,
/// colors, themes, cores, moods, styles, settings, and art direction.
model Facet {
  id                 Int                  @id @default(autoincrement())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime?            @default(now()) @updatedAt
  title              String               @db.VarChar(255)
  slug               String?              @unique @db.VarChar(255)
  kind               FacetKind            @default(OTHER)
  description        String?              @db.Text
  flavorText         String?              @db.VarChar(512)
  examples           String?              @db.LongText
  artPrompt          String?              @db.Text
  imagePath          String?              @db.Text
  cardPath           String?              @db.Text
  heroPath           String?              @db.Text
  icon               String?
  designer           String?              @db.VarChar(256)
  creationSource     CreationSource       @default(HUMAN)
  userId             Int?                 @default(10)
  artImageId         Int?
  artCollectionId    Int?
  isPublic           Boolean              @default(true)
  isMature           Boolean              @default(false)
  isActive           Boolean              @default(true)
  DreamLinks         DreamFacet[]
  ArtCollection      ArtCollection?       @relation("FacetPrimaryArtCollection", fields: [artCollectionId], references: [id])
  ArtImage           ArtImage?            @relation("FacetPrimaryArtImage", fields: [artImageId], references: [id])
  User               User?                @relation(fields: [userId], references: [id])
  FacetAlias         FacetAlias[]
  ArtCollectionLinks FacetArtCollection[]
  ArtImageLinks      FacetArtImage[]
  RelationsFrom      FacetRelation[]      @relation("FacetRelationFrom")
  RelationsTo        FacetRelation[]      @relation("FacetRelationTo")
  Reactions          Reaction[]
  ScenarioLinks      ScenarioFacet[]

  @@index([userId])
  @@index([kind])
  @@index([artImageId])
  @@index([artCollectionId])
  @@index([isPublic])
  @@index([isActive])
}

model DreamFacet {
  dreamId   Int
  facetId   Int
  createdAt DateTime @default(now())
  Dream     Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  Facet     Facet    @relation(fields: [facetId], references: [id], onDelete: Cascade)

  @@id([dreamId, facetId])
  @@index([facetId])
}

model ScenarioFacet {
  scenarioId Int
  facetId    Int
  createdAt  DateTime @default(now())
  Facet      Facet    @relation(fields: [facetId], references: [id], onDelete: Cascade)
  Scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@id([scenarioId, facetId])
  @@index([facetId])
}

model ProjectArtImage {
  projectId  Int
  artImageId Int
  createdAt  DateTime @default(now())
  ArtImage   ArtImage @relation(fields: [artImageId], references: [id], onDelete: Cascade)
  Project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, artImageId])
  @@index([artImageId])
}

model ProjectArtCollection {
  projectId       Int
  artCollectionId Int
  createdAt       DateTime      @default(now())
  ArtCollection   ArtCollection @relation(fields: [artCollectionId], references: [id], onDelete: Cascade)
  Project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, artCollectionId])
  @@index([artCollectionId])
}

model FacetArtImage {
  facetId    Int
  artImageId Int
  createdAt  DateTime @default(now())
  ArtImage   ArtImage @relation(fields: [artImageId], references: [id], onDelete: Cascade)
  Facet      Facet    @relation(fields: [facetId], references: [id], onDelete: Cascade)

  @@id([facetId, artImageId])
  @@index([artImageId])
}

model FacetArtCollection {
  facetId         Int
  artCollectionId Int
  createdAt       DateTime      @default(now())
  ArtCollection   ArtCollection @relation(fields: [artCollectionId], references: [id], onDelete: Cascade)
  Facet           Facet         @relation(fields: [facetId], references: [id], onDelete: Cascade)

  @@id([facetId, artCollectionId])
  @@index([artCollectionId])
}

model FacetRelation {
  id           Int               @id @default(autoincrement())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime?         @default(now()) @updatedAt
  fromFacetId  Int
  toFacetId    Int
  relationType FacetRelationType @default(RELATED)
  note         String?           @db.VarChar(512)
  FromFacet    Facet             @relation("FacetRelationFrom", fields: [fromFacetId], references: [id], onDelete: Cascade)
  ToFacet      Facet             @relation("FacetRelationTo", fields: [toFacetId], references: [id], onDelete: Cascade)

  @@unique([fromFacetId, toFacetId, relationType])
  @@index([fromFacetId])
  @@index([toFacetId])
  @@index([relationType])
}

/// One row per (owner, expression). Holds stills AND reaction videos. Holds both emotions (face-only edits)
/// and actions (pose/state edits), discriminated by `kind`.
/// `NEUTRAL` is the canonical generated narrator avatar.
/// The owner's `artImageId` remains the original portrait / identity anchor.
model ExpressionMedia {
  id                Int            @id @default(autoincrement())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime?      @default(now()) @updatedAt
  expression        Expression     @default(NEUTRAL)
  kind              ExpressionKind @default(EMOTION)
  label             String?        @db.VarChar(256)
  emoticon          String?        @db.VarChar(32)
  expressionKey     String         @db.VarChar(128)
  imagePath         String?        @db.VarChar(764)
  videoPath         String?        @db.VarChar(764)
  artImageId        Int?           @unique
  botId             Int?
  characterId       Int?
  message           String?        @db.Text
  additionalPhrases String?        @db.LongText
  isActive          Boolean        @default(true)
  designer          String?        @db.VarChar(256)
  artPrompt         String?        @db.Text
  ArtImage          ArtImage?      @relation(fields: [artImageId], references: [id])
  Bot               Bot?           @relation(fields: [botId], references: [id])
  Character         Character?     @relation(fields: [characterId], references: [id])

  @@unique([botId, expressionKey])
  @@unique([characterId, expressionKey])
  @@index([artImageId])
  @@index([botId])
  @@index([characterId])
  @@index([kind])
  @@index([expressionKey])
  @@index([botId, kind])
  @@index([characterId, kind])
  @@index([botId, isActive])
  @@index([characterId, isActive])
}

/// A directed transition clip between two expressions for the same owner
/// (bot or character). videoPath holds the FLF2V-generated animated webp that
/// travels fromKey -> toKey. The frontend picks a transition by matching the
/// owner's current expression (fromKey) to the desired target (toKey); if no
/// exact row exists it falls back to the static still on ExpressionMedia.
/// fromKey/toKey are canonical lowercase keys matching ExpressionMedia.expressionKey.
model ExpressionTransition {
  id          Int        @id @default(autoincrement())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime?  @default(now()) @updatedAt
  fromKey     String     @db.VarChar(128)
  toKey       String     @db.VarChar(128)
  videoPath   String     @db.VarChar(764)
  fps         Int        @default(16)
  frames      Int?
  botId       Int?
  characterId Int?
  isActive    Boolean    @default(true)
  designer    String?    @db.VarChar(256)
  Bot         Bot?       @relation(fields: [botId], references: [id])
  Character   Character? @relation(fields: [characterId], references: [id])

  @@unique([botId, fromKey, toKey])
  @@unique([characterId, fromKey, toKey])
  @@index([botId])
  @@index([characterId])
  @@index([botId, fromKey])
  @@index([characterId, fromKey])
  @@index([isActive])
}

/// our woefully underutilized log function, but it's there.
model Log {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  timestamp DateTime @db.DateTime(0)
  username  String?  @db.VarChar(764)
  userId    Int?
  User      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "Log_userId_fkey")
}

/// website achievements! This holds the achievements that can be earned (in the flavor text we refer to them as "jellybeans"). They are not user editable and set by myself. only about 1/3 are currently utilized, and one of my biggest todos before public release.
model Achievement {
  id                 Int                 @id @default(autoincrement())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime?           @default(now()) @updatedAt
  label              String              @db.VarChar(764)
  message            String              @db.VarChar(764)
  icon               String?             @db.VarChar(764)
  karma              Int                 @default(0)
  pageHint           String?             @db.VarChar(764)
  subtleHint         String?             @db.VarChar(764)
  triggerCode        String?             @unique(map: "Milestone_triggerCode_key", length: 255) @db.VarChar(764)
  tooltip            String?             @db.VarChar(764)
  isActive           Boolean             @default(false)
  isRepeatable       Boolean             @default(true)
  artImageId         Int?
  artPrompt          String?             @db.Text
  imagePath          String?             @db.VarChar(764)
  ArtImage           ArtImage?           @relation(fields: [artImageId], references: [id])
  AchievementRecords AchievementRecord[]
  LifeAchievements   LifeAchievement[]
  LifeEndings        LifeEnding[]

  @@index([artImageId], map: "Achievement_artImageId_fkey")
}

model ManaTransaction {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  userId       Int
  amount       Int
  reason       ManaReason
  balanceAfter Int
  refId        String?
