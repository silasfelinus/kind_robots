      "isPublic": true,
      "isMature": false,
      "isActive": true,
      "allowReviews": false
    },
    {
      "title": "Poop Scoop CMS",
      "slug": "humboldt-poop-scoop-cms",
      "dreamType": "PROJECT",
      "projectStatus": "ACTIVE",
      "description": "New customer-management software for a poop-scoop service. Tracks customers, pets and yards, service schedules, visit logs, and billing.",
      "pitch": "Build with seed/dummy data only until Silas approves going live.",
