generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// Art is the old art directory asset. It didn't have the data itself, but could point to the data. I'm now phazing it out as it makes more sense to point directly to the artImage and filter out the data when needed, but there is still a lot of imagePath stored that needs to be migrated before Art can retire
model Art {
  id                   Int             @id @default(autoincrement())
  createdAt            DateTime?       @default(now())
  updatedAt            DateTime?       @default(now()) @updatedAt
  path                 String?         @default("UNDEFINED") @db.VarChar(764)
  checkpoint           String?         @db.VarChar(256)
  checkpointResourceId Int?
  sampler              String?         @db.VarChar(764)
  seed                 Int?            @default(-1)
  steps                Int?
  designer             String?         @db.VarChar(764)
  isPublic             Boolean?        @default(false)
  isMature             Boolean?        @default(false)
  isActive             Boolean        @default(true)
  promptId             Int?
  userId               Int?            @default(10)
  pitchId              Int?
  galleryId            Int?            @default(21)
  promptString         String          @db.Text
  cfg                  Int?            @default(3)
  cfgHalf              Boolean?        @default(false)
  serverId             Int?
  serverName           String?         @db.VarChar(256)
  serverUrl            String?         @db.VarChar(764)
  artImageId           Int?
  imagePath            String?
  genres               String?
  negativePrompt       String?         @db.Text

  CheckpointResource   Resource?       @relation("ArtCheckpointResource", fields: [checkpointResourceId], references: [id])
  Gallery              Gallery?        @relation(fields: [galleryId], references: [id])
  Pitch                Pitch?          @relation(fields: [pitchId], references: [id])
  Prompt               Prompt?         @relation(fields: [promptId], references: [id])
  Server               Server?         @relation(fields: [serverId], references: [id])
  User                 User?           @relation(fields: [userId], references: [id])
  ArtImage             ArtImage?
  Reaction             Reaction[]
  Dreams               Dream[]
  Butterflies          Butterfly[]
  Tags                 Tag[]           @relation("ArtToTag")
  ArtCollection        ArtCollection[] @relation("ArtToArtCollection")

  @@index([galleryId], map: "Art_galleryId_fkey")
  @@index([pitchId], map: "Art_pitchId_fkey")
  @@index([promptId], map: "Art_promptId_fkey")
  @@index([userId], map: "Art_userId_fkey")
  @@index([serverId], map: "Art_serverId_fkey")
  @@index([checkpointResourceId], map: "Art_checkpointResourceId_fkey")
}

/// ArtImage is meant to be grabbed as needed, to avoid data bloat. The primary element is imageData
model ArtImage {
  id                   Int             @id @default(autoincrement())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime?       @default(now()) @updatedAt
  galleryId            Int?            @default(21)
  userId               Int?            @default(10)

  // Image data
  imageData            String?          @db.LongText
  thumbnailData        String?         @db.MediumText
  fileName             String?         @db.VarChar(764)
  fileType             String          @default("png")
  artPrompt  String?  @db.Text
  
  imagePath            String?
  rarity               Int?

  // Generation metadata (migrated from Art)
  path                 String?         @db.VarChar(764)
  promptString         String?         @db.Text
  negativePrompt       String?         @db.Text
  checkpoint           String?         @db.VarChar(256)
  checkpointResourceId Int?
  sampler              String?         @db.VarChar(764)
  seed                 Int?            @default(-1)
  steps                Int?
  cfg                  Int?            @default(3)
  cfgHalf              Boolean?        @default(false)
  designer             String?         @db.VarChar(764)
  genres               String?

  // Content flags
  isPublic             Boolean?        @default(false)
  isMature             Boolean?        @default(false)
  isActive             Boolean        @default(true)

  // Server info
  serverId             Int?
  serverName           String?         @db.VarChar(256)
  serverUrl            String?         @db.VarChar(764)

  // Foreign keys (one-to-one ownership: this image belongs to one of these)
  artId                Int?            @unique
  botId                Int?            @unique
  componentId          Int?            @unique
  milestoneId          Int?            @unique
  pitchId              Int?            @unique
  promptId             Int?            @unique
  resourceId           Int?            @unique
  rewardId             Int?            @unique
  chatId               Int?            @unique
  characterId          Int?            @unique
  butterflyId          Int?            @unique

  // Relations — one-to-one owners
  Art                  Art?            @relation(fields: [artId], references: [id])
  Bot                  Bot?            @relation(fields: [botId], references: [id])


Character   Character? @relation(fields: [characterId], references: [id])
  Chat                 Chat?           @relation(fields: [chatId], references: [id])
  Component            Component?      @relation(fields: [componentId], references: [id])
  Gallery              Gallery?        @relation(fields: [galleryId], references: [id])
  Milestone            Milestone?      @relation(fields: [milestoneId], references: [id])
  Pitch                Pitch?          @relation(fields: [pitchId], references: [id])
  Prompt               Prompt?         @relation(fields: [promptId], references: [id])
  Resource             Resource?       @relation(fields: [resourceId], references: [id])
  Reward               Reward?         @relation(fields: [rewardId], references: [id])
  User                 User?           @relation(fields: [userId], references: [id])
  Server               Server?         @relation(fields: [serverId], references: [id])
  CheckpointResource   Resource?       @relation("ArtImageCheckpointResource", fields: [checkpointResourceId], references: [id])

  // Relations — one-to-many (this image appears in many)
  Butterflies          Butterfly[]
  Scenarios            Scenario[]
  Dreams               Dream[]
  Reactions            Reaction[]
  Tags                 Tag[]           @relation("ArtImageToTag")
 // back-reference: which Tag claims this image as its representative
  TagOwner             Tag?            @relation("TagRepresentativeImage") 
  // Implicit M2M — an image can belong to many collections
  ArtCollections       ArtCollection[]

  @@index([galleryId],            map: "ArtImage_galleryId_fkey")
  @@index([userId],               map: "ArtImage_userId_fkey")
  @@index([artId],                map: "ArtImage_artId_fkey")
  @@index([serverId],             map: "ArtImage_serverId_fkey")
  @@index([checkpointResourceId], map: "ArtImage_checkpointResourceId_fkey")
  @@index([pitchId],              map: "ArtImage_pitchId_fkey")
  @@index([promptId],             map: "ArtImage_promptId_fkey")
}

model ArtCollection {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  userId      Int       @default(10)
  label       String?

  isMature    Boolean   @default(false)
  isPublic    Boolean   @default(true)
  isActive             Boolean        @default(true)
  artPrompt  String?  @db.Text

  description String?
  username    String?
  User        User      @relation(fields: [userId], references: [id])
  art         Art[]     @relation("ArtToArtCollection")
  Dreams       Dream[]
  Butterflies Butterfly[]
  Reactions Reaction[]
  ArtImages   ArtImage[]

  @@index([userId], map: "ArtCollection_userId_fkey")
}

model Bot {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime?  @default(now()) @updatedAt
  BotType           String     @db.VarChar(764)
  name              String     @unique(map: "Bot_id_key", length: 200) @db.VarChar(256)
  subtitle          String?    @db.VarChar(764)
  description       String?    @db.VarChar(764)
  avatarImage       String?    @db.VarChar(764)
  botIntro          String     @db.VarChar(3000)
  userIntro         String     @db.VarChar(764)
  prompt            String     @db.VarChar(764)
  trainingPath      String?    @db.VarChar(764)
  theme             String?    @db.VarChar(764)
  personality       String?    @db.VarChar(764)
  modules           String?    @db.VarChar(764)
  sampleResponse    String?    @db.VarChar(764)
  tagline           String?    @db.VarChar(764)
  artPrompt  String?  @db.Text

  isPublic        Boolean         @default(true)
  isMature        Boolean         @default(false)
  isActive             Boolean        @default(true)

  underConstruction Boolean    @default(false)
  canDelete         Boolean    @default(false)
  userId            Int?       @default(1)
  designer          String     @default("silasfelinus")
  serverId          Int?
  serverName        String?    @db.VarChar(256)
  artImageId        Int?
  ArtImage          ArtImage?
  Server            Server?    @relation(fields: [serverId], references: [id])
  User              User?      @relation(fields: [userId], references: [id])
  Chats             Chat[]
  Prompts           Prompt[]
  Reactions         Reaction[]
  Butterflies Butterfly[]

  @@index([userId], map: "Bot_userId_fkey")
  @@index([serverId], map: "Bot_serverId_fkey")
}

/// Butterfly is the source of truth for each collectible species.
/// Runtime-only fields (x, y, z, goal, rotation, status, zIndex) live in the
/// butterflyStore — nothing positional is persisted here.
/// name and message are the personality core; treat them as immutable post-seed.
/// wingTopColor / wingBottomColor stored as HSL strings: "hsl(210,70%,55%)"
model Butterfly {
  id              Int                @id @default(autoincrement())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime?          @default(now()) @updatedAt

  /// The funny generated name — also used as display identity in the game UI.
  /// Maps to the `id` field in butterflyHelper's Butterfly interface at runtime.
  name            String             @unique @db.VarChar(255)

  /// One-line character description shown in the capture modal.
  message         String             @db.VarChar(764)

  /// Stored so the gallery can render caught butterflies without spawning them.
  wingTopColor    String             @db.VarChar(64)
  wingBottomColor String             @db.VarChar(64)

  /// Flight personality — read by createNewButterfly() at spawn time.
  /// speed maps to butterflyHelper speedRange output (Float, e.g. 0.3–0.8)
  /// wingSpeed maps to wingSpeedRange output (Float, e.g. 0.06–0.15)
  /// scale maps to the scale field on the Butterfly interface (Float, e.g. 0.7–1.3)
  speed           Float
  wingSpeed       Float
  scale           Float

  /// Stable 1-based slot index for the field guide gallery.
  /// Assigned at seed time and never changed — it's the gallery key.
  rarityNumber    Int                @unique

  /// Optional: attach art to a butterfly for a richer gallery detail view later.
  artImageId      Int?               @unique
  ArtImage        ArtImage?          @relation(fields: [artImageId], references: [id])

  designer        String?            @db.VarChar(255)
  userId          Int?               @default(1)
  isPublic        Boolean            @default(true)

  User            User?              @relation(fields: [userId], references: [id])
  Collections     ButterflyRecord[]

  artId           Int?
  artCollectionId Int?
  botId           Int?
  characterId     Int?
  pitchId         Int?
  promptId        Int?
  scenarioId      Int?
  tagId           Int?

  Art             Art?           @relation(fields: [artId], references: [id])
  ArtCollection   ArtCollection? @relation(fields: [artCollectionId], references: [id])
  Bot             Bot?           @relation(fields: [botId], references: [id])
  Pitch           Pitch?         @relation(fields: [pitchId], references: [id])
  Prompt          Prompt?        @relation(fields: [promptId], references: [id])
  Reactions       Reaction[]
  Scenario        Scenario?      @relation(fields: [scenarioId], references: [id])
  Tag             Tag?           @relation(fields: [tagId], references: [id])

  @@index([userId], map: "Butterfly_userId_fkey")
  @@index([artId],           map: "Butterfly_artId_fkey")
  @@index([artCollectionId], map: "Butterfly_artCollectionId_fkey")
  @@index([botId],           map: "Butterfly_botId_fkey")
  @@index([characterId],     map: "Butterfly_characterId_fkey")
  @@index([pitchId],         map: "Butterfly_pitchId_fkey")
  @@index([promptId],        map: "Butterfly_promptId_fkey")
  @@index([scenarioId],      map: "Butterfly_scenarioId_fkey")
  @@index([tagId],           map: "Butterfly_tagId_fkey")
}

/// Records which butterflies each user has caught.
/// Follows the MilestoneRecord pattern rather than implicit M2M,
/// so we can attach caughtAt and any future metadata cleanly.
model ButterflyRecord {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt

  userId      Int
  butterflyId Int

  User        User      @relation(fields: [userId], references: [id])
  Butterfly   Butterfly @relation(fields: [butterflyId], references: [id])

  @@unique([userId, butterflyId])
  @@index([userId],      map: "ButterflyRecord_userId_fkey")
  @@index([butterflyId], map: "ButterflyRecord_butterflyId_fkey")
}



model Character {
  id             Int       @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @default(now()) @updatedAt

  name           String    @db.VarChar(256)
  honorific      String?   @default("adventurer") @db.VarChar(256)
  title          String?   @db.VarChar(256)

  role           String?   @db.VarChar(256)
  class          String?   @db.VarChar(764)
  species        String?   @db.VarChar(764)
  gender         String?   @db.VarChar(256)
  presentation   String?   @db.VarChar(764)

  genre          String?   @db.VarChar(256)
  alignment      String?   @db.VarChar(256)
  personality    String?   @db.Text
  drive          String?   @db.VarChar(764)
  backstory      String?   @db.Text
  achievements   String?   @db.VarChar(764)
  quirks         String?   @db.Text

  luck           Rarity    @default(COMMON)
  might          Rarity    @default(COMMON)
  wits           Rarity    @default(COMMON)
  grace          Rarity    @default(COMMON)
  charm          Rarity    @default(COMMON)
  empathy        Rarity    @default(COMMON)

  artPrompt      String?   @db.Text
  artImageId     Int?
  imagePath      String?   @db.VarChar(764)

  experience     Int       @default(0)
  level          Int       @default(1)

  designer       String?   @db.VarChar(256)
  isPublic       Boolean   @default(true)
  isMature       Boolean   @default(false)
  isActive       Boolean   @default(true)
  userId         Int       @default(10)

  ArtImage       ArtImage?
  User           User      @relation(fields: [userId], references: [id])

  Chats          Chat[]
  Reactions      Reaction[]
  Rewards        Reward[]   @relation("CharacterToReward")
  Scenarios      Scenario[] @relation("CharacterToScenario")
  Dreams         Dream[]    @relation("CharacterToDream")

  @@index([userId], map: "Character_userId_fkey")
  @@index([isPublic])
  @@index([isActive])
  @@index([name])
}

/// a chat can be between users, user to Bot or Character, on to a Forum or Channel (aka chatroom)
/// originId should always be shared in subsequent messages so we can track the thread via originID and createdAt
/// splitting the chat into a new thread creates a fresh originId
model Chat {
  id              Int        @id @default(autoincrement())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime?  @default(now()) @updatedAt
  type            ChatType
  sender          String     @db.VarChar(255)
  recipient       String?    @db.VarChar(255)
  content         String     @db.Text
  title           String?    @db.VarChar(255)
  isFavorite      Boolean    @default(false)
  previousEntryId Int?
  originId        Int?
  userId          Int?
  botId           Int?
  recipientId     Int?
  artImageId      Int?
  promptId        Int?
  botName         String?    @db.VarChar(255)
  channel         String?    @db.VarChar(255)
  botResponse     String?
  characterId     Int?
  isRead          Boolean    @default(false)

  isPublic        Boolean    @default(true)
  isActive        Boolean    @default(true)
  isMature        Boolean    @default(false)

  dreamId         Int?
  serverId        Int?
  serverName      String?    @db.VarChar(256)
  ArtImage        ArtImage?
  Bot             Bot?       @relation(fields: [botId], references: [id])
  Character       Character? @relation(fields: [characterId], references: [id])
  Prompt          Prompt?    @relation(fields: [promptId], references: [id])
  Server          Server?    @relation(fields: [serverId], references: [id])
  User            User?      @relation(fields: [userId], references: [id])
  Reactions       Reaction[]
  Dream           Dream?     @relation(fields: [dreamId], references: [id], onDelete: Cascade)

  @@index([serverId], map: "Chat_serverId_fkey")
  @@index([botId], map: "Chat_botId_fkey")
  @@index([characterId], map: "Chat_characterId_fkey")
  @@index([promptId], map: "Chat_promptId_fkey")
  @@index([userId], map: "Chat_userId_fkey")
  @@index([dreamId], map: "Chat_dreamId_fkey")
}

/// Components track all the components we use making kindrobots. it's primary uses are as a museum of developmental attemps, while allowing reactions to allow sifting concepts and allowing the best to rise to attention.
model Component {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime?  @default(now()) @updatedAt
  folderName        String
  componentName     String     @unique
  isWorking         Boolean    @default(true)
  underConstruction Boolean    @default(false)
  isBroken          Boolean    @default(false)
  title             String?
  notes             String?
  artImageId        Int?
  ArtImage          ArtImage?
  Reactions         Reaction[]
  Tags              Tag[]      @relation("ComponentToTag")
}


model Dream {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @default(now()) @updatedAt

  title           String          @db.VarChar(255)
  slug            String?         @unique @db.VarChar(255)
  description     String?         @db.Text

  currentVibe     String?          @db.Text
  currentPrompt   String?         @db.Text

  userId          Int             @default(10)
  pitchId         Int?
  artId           Int?
  artImageId      Int?
  textServerId    Int?
  artServerId     Int?
  artCollectionId Int?
  galleryId       Int?
  scenarioId      Int?
  artPrompt       String?         @db.Text

  accessMode      DreamAccessMode @default(OPEN)
  privacyCode     String?         @db.VarChar(255)

  isPublic        Boolean         @default(true)
  isMature        Boolean         @default(false)
  isActive        Boolean         @default(true)

  User            User            @relation(fields: [userId], references: [id])
  Gallery         Gallery?        @relation(fields: [galleryId], references: [id])
  Pitch           Pitch?          @relation(fields: [pitchId], references: [id])
  Art             Art?            @relation(fields: [artId], references: [id])
  Scenario        Scenario?       @relation(fields: [scenarioId], references: [id])
  ArtImage        ArtImage?       @relation(fields: [artImageId], references: [id])
  ArtCollection   ArtCollection?  @relation(fields: [artCollectionId], references: [id])

  Chats           Chat[]
  Reactions       Reaction[]
  Tags            Tag[]           @relation("DreamToTag")
  Characters      Character[]     @relation("CharacterToDream")
  Rewards         Reward[]        @relation("DreamToReward")

  @@index([userId])
  @@index([accessMode])
  @@index([isPublic])
  @@index([isActive])
}

enum DreamAccessMode {
  OPEN
  CODE
  PRIVATE
  SOLO
}



/// our mostly-obsolete system for collecting images. It assumed data was kept as physical files on disk, and is still used to access the original seed images, which are only partly digitized and used primarily for our Memory Match game, which is the clearest proof of concept that all of this can be used for a functional purpose.
model Gallery {
  id             Int        @id @default(autoincrement())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime?  @default(now()) @updatedAt
  name           String     @db.VarChar(256)
  description    String?    @db.Text
  url            String?    @db.VarChar(256)
  custodian      String?    @db.VarChar(256)
  content        String     @db.VarChar(764)
  highlightImage String?    @db.VarChar(256)
  imagePaths     String?    @db.Text
  userId         Int?       @default(1)

  isPublic       Boolean    @default(true)
  isActive             Boolean        @default(true)
  isMature             Boolean        @default(false)

  Art            Art[]
  ArtImage       ArtImage[]
  User           User?      @relation(fields: [userId], references: [id])
  Prompts        Prompt[]
  Reactions      Reaction[]
  Dreams       Dream[]
  

  @@index([userId], map: "Gallery_userId_fkey")
}

/// our woefully underutilized log function, but it's there.
model Log {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  timestamp DateTime @db.DateTime(0)
  username  String?  @db.VarChar(764)
  userId    Int?
  User      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "Log_userId_fkey")
}

/// website achievements! This holds the milestones that can be achieved (in the flavor text we refer to them as "jellybeans"). They are not user editable and set by myself. only about 1/3 are currently utilized, and one of my biggest todos before public release.
model Milestone {
  id               Int               @id @default(autoincrement())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @default(now()) @updatedAt
  label            String            @db.VarChar(764)
  message          String            @db.VarChar(764)
  icon             String?           @db.VarChar(764)
  karma            Int               @default(0)
  pageHint         String?           @db.VarChar(764)
  subtleHint       String?           @db.VarChar(764)
  triggerCode      String?           @db.VarChar(764)
  tooltip          String?           @db.VarChar(764)
  isActive         Boolean           @default(false)
  isRepeatable     Boolean           @default(true)
  artPrompt  String?  @db.Text
  artImageId       Int?
  ArtImage         ArtImage?
  MilestoneRecords MilestoneRecord[]
}

/// the records of milestones earned. They record the date, username, id, etc. Users are given the option to clear their milestones so they can hunt fresh. I use this extensively in debugging.
model MilestoneRecord {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  username    String?   @db.VarChar(764)
  milestoneId Int
  userId      Int
  isConfirmed Boolean   @default(false)
  Milestones  Milestone @relation(fields: [milestoneId], references: [id])
  User        User      @relation(fields: [userId], references: [id])

  @@index([milestoneId], map: "MilestoneRecord_milestoneId_fkey")
  @@index([userId], map: "MilestoneRecord_userId_fkey")
}

/// A Pitch is a big picture idea that is meant to be fuel for a project that can become art assets, text assets, and physical swag. A Pitch can contain a collection of Prompts, which is an implementation of the Pitch. for example, a Pitch of "wild colors" could contain a series of prompts like "lavender armadillo;  green curd; rainbow sunburn". it can be represented by an artImage for it's overall vibe, but also collect Art objects if they are inspired by the Pitch 
model Pitch {
  id             Int        @id @default(autoincrement())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime?  @default(now()) @updatedAt
  title          String?    @db.VarChar(256)
  pitch          String     @db.VarChar(764)
  designer       String?    @db.VarChar(256)
  flavorText     String?    @db.VarChar(512)
  highlightImage String?    @db.VarChar(256)
  PitchType      PitchType  @default(ARTPITCH)
  creationSource CreationSource @default(HUMAN)
  artPrompt  String?  @db.Text

  isMature       Boolean    @default(false)
  isPublic       Boolean    @default(true)
  isActive             Boolean        @default(true)

  userId         Int?       @default(1)
  description    String?    @db.VarChar(256)
  artImageId     Int?
  examples       String?    @db.LongText
  icon           String?
  Art            Art[]
  ArtImage       ArtImage?
  User           User?      @relation(fields: [userId], references: [id])
  Prompts        Prompt[]
  Reactions      Reaction[]
  Tags           Tag[]      @relation("PitchToTag")
  Butterflies Butterfly[]
  Dreams              Dream[]

  @@index([userId], map: "Pitch_userId_fkey")
}

/// this is an art or text prompt to an ai to generate new media
model Prompt {
  id         Int        @id @default(autoincrement())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime?  @default(now()) @updatedAt
  prompt     String     @db.Text
  userId     Int?       @default(1)
  galleryId  Int?       @default(21)
  artPrompt  String?  @db.Text

  isMature       Boolean    @default(false)
  isPublic       Boolean    @default(true)
  isActive       Boolean    @default(true)

  creationSource CreationSource @default(HUMAN)
  pitchId    Int?
  botId      Int?
  artImageId Int?
  Art        Art[]
  ArtImage   ArtImage?
  Chats      Chat[]
  Bot        Bot?       @relation(fields: [botId], references: [id])
  Gallery    Gallery?   @relation(fields: [galleryId], references: [id])
  Pitch      Pitch?     @relation(fields: [pitchId], references: [id])
