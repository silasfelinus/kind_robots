/// Hair by Superkate suite: a stylist's client book. Owned by the studio user
/// (userId); private business data, never surfaced publicly. Replaces the
/// suite's localStorage mock so the client book syncs across devices.
model StylistClient {
  id           Int                  @id @default(autoincrement())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime?            @default(now()) @updatedAt
  userId       Int
  name         String               @db.VarChar(255)
  email        String?              @db.VarChar(255)
  Appointments StylistAppointment[]
  User         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Hair by Superkate suite: saved appointments. clientName is a snapshot so
/// history survives client deletion (delete-detach); money is stored in cents.
model StylistAppointment {
  id               Int            @id @default(autoincrement())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime?      @default(now()) @updatedAt
  userId           Int
  clientId         Int?
  clientName       String         @db.VarChar(255)
  date             String         @db.VarChar(10)
  hourlyRateCents  Int            @default(0)
  minutes          Int            @default(0)
  productCostCents Int            @default(0)
  totalCents       Int            @default(0)
  Client           StylistClient? @relation(fields: [clientId], references: [id])
  User             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}

/// Durable art generation job queue. Producers (conductor scripts, UI) enqueue
/// jobs; the home relay agent claims them outward (pull model — the server never
/// dials into the home network), drives local ComfyUI/A1111, uploads the result
/// via /api/art/save-generated, then marks the job complete with the ArtImage id.
/// Claiming is atomic (guarded updateMany); RUNNING jobs whose claim has gone
/// stale are re-claimable so a crashed relay never strands work.
model ArtJob {
  id          Int          @id @default(autoincrement())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime?    @default(now()) @updatedAt
  status      ArtJobStatus @default(PENDING)
  engine      ServerType   @default(A1111)
  payload     String       @db.LongText
  priority    Int          @default(0)
  attempts    Int          @default(0)
  claimedAt   DateTime?
  claimedBy   String?      @db.VarChar(255)
  projectSlug String?      @db.VarChar(255)
  artImageId  Int?
  error       String?      @db.Text
  userId      Int
  projectId   Int?
  Project     Project?     @relation(fields: [projectId], references: [id])
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, priority, id])
  @@index([userId])
  @@index([projectSlug])
  @@index([projectId])
}

/// Economy: karma ledger — separate from mana, tracks community contribution score
model KarmaTransaction {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
