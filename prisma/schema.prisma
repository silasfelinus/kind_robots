  @@index([status])
  @@index([audience])
}

model SocialTarget {
  id           Int            @id @default(autoincrement())
  postId       Int
  platform     SocialPlatform
  status       TargetStatus   @default(PENDING)
  remoteId     String?
  remoteUrl    String?
  errorMessage String?
  sentAt       DateTime?
  Post         SocialPost     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, platform])
  @@index([postId])
  @@index([platform])
  @@index([status])
