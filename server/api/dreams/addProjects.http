### ── 6. brainstorm ────────────────────────────────────────────────────────────
POST {{base}}/dreams
Content-Type: application/json
Authorization: Bearer {{admintoken}}

{
  "title": "Brainstorm",
  "slug": "brainstorm",
  "dreamType": "PROJECT",
  "projectStatus": "ACTIVE",
  "description": "Ongoing proposal generation: AI workers surface ideas for Silas to vote on. Quality over quantity — max 3 new pitches per cycle. Respects CONTROL.md genre guidance and product-type constraints.",
  "pitch": "Generate ideas for Silas to vote on. The Worker never implements; it only writes the pitch.",
  "flavorText": "Ideas are cheap. Good ideas, less so.",
