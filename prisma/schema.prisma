enum ArtJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

/// Durable art generation job queue. Producers (conductor scripts, UI) enqueue
/// jobs; the home relay agent claims them outward (pull model — the server never
/// dials into the home network), drives local ComfyUI/A1111, uploads the result
/// via /api/art/save-generated, then marks the job complete with the ArtImage id.
/// Claiming is atomic (guarded updateMany); RUNNING jobs whose claim has gone
/// stale are re-claimable so a crashed relay never strands work.
model ArtJob {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now()) @updatedAt

  status   ArtJobStatus @default(PENDING)
  engine   ServerType   @default(A1111)
  payload  Json
  priority Int          @default(0)
  attempts Int          @default(0)

  claimedAt DateTime?
  claimedBy String?   @db.VarChar(255)

  projectSlug String? @db.VarChar(255)
  artImageId  Int?
  error       String? @db.Text

  userId Int
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, priority, id])
  @@index([userId])
  @@index([projectSlug])
}

/// Economy: karma ledger — separate from mana, tracks community contribution score
model KarmaTransaction {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  userId       Int
  amount       Int
  reason       KarmaReason
  balanceAfter Int
  refId        String?
  note         String?     @db.Text
  User         User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

/// Referral tracking — data layer only; cut payment logic is needs-human
model Referral {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  referrerId Int
  referredId Int      @unique
  codeUsed   String?  @db.VarChar(64)
  cutRate    Float    @default(0.05)
  Referrer   User     @relation("ReferralsMade", fields: [referrerId], references: [id])
  Referred   User     @relation("ReferredBy", fields: [referredId], references: [id])

  @@index([referrerId])
}

enum RelationType {
  FRIEND
  BLOCK
  PARENT
  CHILD
  REFEREE
}

enum RelationStatus {
  PENDING // requested by userId, not yet accepted by relatedUserId
  ACCEPTED // active relationship
  DECLINED // relatedUserId declined; kept for history/anti-spam, or hard-delete
}

/// Directed relationship between two users with a typed role.
/// One row per (userId, relatedUserId, type). Symmetric types (FRIEND) are
/// normalized in the app layer so a single row represents the mutual link.
/// Follows the ButterflyRecord/MilestoneRecord pattern (explicit join model,
/// not implicit M2M) so we can attach status + timestamps + future metadata.
model UserRelation {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime?      @default(now()) @updatedAt
  userId        Int
  relatedUserId Int
  type          RelationType
  status        RelationStatus @default(PENDING)
  note          String?        @db.Text
  pairId        Int?

  User        User @relation("UserRelationOwner", fields: [userId], references: [id])
  RelatedUser User @relation("UserRelationTarget", fields: [relatedUserId], references: [id])

  // Prevents duplicate links of the same type between the same ordered pair.
  // A user can both FRIEND and (later) BLOCK someone — different type, allowed.
  @@unique([userId, relatedUserId, type])
  @@index([userId], map: "UserRelation_userId_fkey")
  @@index([relatedUserId], map: "UserRelation_relatedUserId_fkey")
  @@index([type])
  @@index([status])
  @@index([pairId])
}

