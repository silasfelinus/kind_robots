# Create new brainstorm Dream entries
# Run after migration is applied and server is running.
# Set @token to your admin JWT before executing.

@baseUrl = http://localhost:3000
@token = YOUR_ADMIN_TOKEN_HERE

###
# 1. Art Generator Connect
POST {{baseUrl}}/api/dreams
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Art Generator Connect",
  "slug": "art-generator-connect",
  "dreamType": "PROJECT",
  "projectStatus": "BRAINSTORM",
  "description": "Wire conductor Worker cycles into the existing SD / ComfyUI automated pipelines already running in kind_robots. Workers can request image generation by POSTing to the art API; the result URL is committed back to the project or stored as an ArtImage record.",
  "pitch": "Let agents generate their own art — no manual prompting required.",
  "flavorText": "The AI that paints itself.",
  "isPublic": false
}

