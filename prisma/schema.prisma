  @@index([userId, createdAt])
}

/// Referral tracking — data layer only; cut payment logic is needs-human
model Referral {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())
  referrerId Int
  referredId Int      @unique
  codeUsed   String?  @db.VarChar(64)
