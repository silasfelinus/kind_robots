### Patch all Conductor projects: local image paths + correct statuses
@base = https://kind-robots.vercel.app/api
@admintoken = {{$dotenv ADMIN_TOKEN}}
@imgbase = /images/projects

### Kind Robots (id 273)
PATCH {{base}}/dreams/273
Content-Type: application/json
x-admin-token: {{admintoken}}

{
  "imagePath": "{{imgbase}}/kind-robots-icon.webp",
  "cardPath": "{{imgbase}}/kind-robots-card.webp",
  "heroPath": "{{imgbase}}/kind-robots-hero.webp",
  "projectStatus": "ACTIVE"
}

