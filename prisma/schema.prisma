  title           String    @db.VarChar(255)
  subtitle        String?   @db.VarChar(512)
  hook            String?   @db.VarChar(512)
  pitch           String?   @db.Text
  highlight1Label String?   @db.VarChar(128)
  highlight1Value String?   @db.VarChar(512)
  highlight1Icon  String?   @db.VarChar(255)
  highlight2Label String?   @db.VarChar(128)
  highlight2Value String?   @db.VarChar(512)
  highlight2Icon  String?   @db.VarChar(255)
  highlight3Label String?   @db.VarChar(128)
  highlight3Value String?   @db.VarChar(512)
  highlight3Icon  String?   @db.VarChar(255)
  detail1Label    String?   @db.VarChar(128)
  detail1Body     String?   @db.Text
  detail2Label    String?   @db.VarChar(128)
  detail2Body     String?   @db.Text
  detail3Label    String?   @db.VarChar(128)
  detail3Body     String?   @db.Text
  imagePath       String?   @db.VarChar(764)
