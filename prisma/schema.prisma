generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

/// ArtImage is meant to be grabbed as needed, to avoid data bloat. The primary element is imageData
model ArtImage {
  id                           Int             @id @default(autoincrement())
  imageData                    String?         @db.LongText
  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime?       @default(now()) @updatedAt
  userId                       Int?            @default(10)
  fileName                     String?         @db.VarChar(764)
  fileType                     String          @default("png")
  cfg                          Int?            @default(3)
  cfgHalf                      Boolean?        @default(false)
  checkpoint                   String?         @db.VarChar(256)
  checkpointResourceId         Int?
  designer                     String?         @db.VarChar(764)
  genres                       String?
  imagePath                    String?
  isMature                     Boolean?        @default(false)
  isPublic                     Boolean?        @default(false)
  negativePrompt               String?         @db.Text
  path                         String?         @db.VarChar(764)
  promptString                 String?         @db.Text
  sampler                      String?         @db.VarChar(764)
  seed                         Int?            @default(-1)
  serverId                     Int?
  serverName                   String?         @db.VarChar(256)
  serverUrl                    String?         @db.VarChar(764)
  steps                        Int?
  thumbnailData                String?         @db.MediumText
  isActive                     Boolean         @default(true)
  artPrompt                    String?         @db.Text
  CheckpointResource           Resource?       @relation("ArtImageCheckpointResource", fields: [checkpointResourceId], references: [id])
  Server                       Server?         @relation("ArtImageGeneratorServer", fields: [serverId], references: [id])
  User                         User?           @relation("ArtImageCreator", fields: [userId], references: [id])
  Bots                         Bot[]
  Characters                   Character[]
  Chats                        Chat[]
  Components                   Component[]
  Dreams                       Dream[]
  Milestones                   Milestone[]
  Pitches                      Pitch[]
  Prompts                      Prompt[]
  Reactions                    Reaction[]
  Resources        Resource[]  @relation("ResourcePreviewImage")
  LoraResources    Resource[]  @relation("ArtImageLoraResources")     
  Rewards                      Reward[]
  Scenarios                    Scenario[]
  UserProfiles                 User[]          @relation("UserProfileImage")
  ArtCollections               ArtCollection[] @relation("ArtCollectionToArtImage")
  Compositions  Composition[]

  @@index([userId],               map: "ArtImage_userId_fkey")
  @@index([checkpointResourceId], map: "ArtImage_checkpointResourceId_fkey")
  @@index([serverId],             map: "ArtImage_serverId_fkey")
}

model ArtCollection {
  id                              Int         @id @default(autoincrement())
  createdAt                       DateTime    @default(now())
  updatedAt                       DateTime?   @default(now()) @updatedAt
  userId      Int         @default(10)
  label       String?
  isMature    Boolean     @default(false)
  isPublic    Boolean     @default(true)
  description String?
  username    String?
  isActive    Boolean     @default(true)
  artPrompt   String?     @db.Text
  User        User        @relation(fields: [userId], references: [id])
  Dreams       Dream[]
  Reactions   Reaction[]
  ArtImages   ArtImage[]  @relation("ArtCollectionToArtImage")

  @@index([userId], map: "ArtCollection_userId_fkey")
}

model Bot {
  id                Int         @id @default(autoincrement())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime?   @default(now()) @updatedAt
  BotType           String      @db.VarChar(764)
  name              String      @unique(map: "Bot_id_key", length: 200) @db.VarChar(256)
  subtitle          String?     @db.VarChar(764)
  description       String?     @db.VarChar(764)
  avatarImage       String?     @db.VarChar(764)
  botIntro          String      @db.VarChar(3000)
  userIntro         String      @db.VarChar(764)
  prompt            String      @db.VarChar(764)
  trainingPath      String?     @db.VarChar(764)
  theme             String?     @db.VarChar(764)
  personality       String?     @db.VarChar(764)
  modules           String?     @db.VarChar(764)
  sampleResponse    String?     @db.VarChar(764)
  tagline           String?     @db.VarChar(764)
  isPublic          Boolean     @default(true)
  underConstruction Boolean     @default(false)
  canDelete         Boolean     @default(false)
  userId            Int?        @default(1)
  designer          String      @default("silasfelinus")
  serverId          Int?
  serverName        String?     @db.VarChar(256)
  artImageId        Int?
  isMature          Boolean     @default(false)
  isActive          Boolean     @default(true)
  artPrompt         String?     @db.Text
  ArtImage          ArtImage?   @relation(fields: [artImageId], references: [id])
  Server            Server?     @relation(fields: [serverId], references: [id])
  User              User?       @relation(fields: [userId], references: [id])
  Chats             Chat[]
  Prompts            Prompt[]
  Reactions         Reaction[]

  @@index([userId], map: "Bot_userId_fkey")
  @@index([serverId], map: "Bot_serverId_fkey")
  @@index([artImageId], map: "Bot_artImageId_fkey")
}

/// Butterfly is the source of truth for each collectible species.
model Butterfly {
  id              Int               @id @default(autoincrement())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @default(now()) @updatedAt
  name            String            @unique @db.VarChar(255)
  message         String            @db.VarChar(764)
  
  wingTopColor    String            @db.VarChar(64)
  wingBottomColor String            @db.VarChar(64)
  speed           Float
  wingSpeed       Float
  scale           Float
  rarityNumber    Int               @unique
  designer        String?           @db.VarChar(255)
  userId          Int?              @default(1)
  isPublic        Boolean           @default(true)
  User            User?             @relation(fields: [userId], references: [id])
  Collections     ButterflyRecord[]
  Reactions       Reaction[]

  @@index([userId], map: "Butterfly_userId_fkey")

}

/// Records which butterflies each user has caught.
/// Follows the MilestoneRecord pattern rather than implicit M2M,
/// so we can attach caughtAt and any future metadata cleanly.
model ButterflyRecord {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  userId      Int
  butterflyId Int
  Butterfly   Butterfly @relation(fields: [butterflyId], references: [id])
  User        User      @relation(fields: [userId], references: [id])

  @@unique([userId, butterflyId])
  @@index([userId], map: "ButterflyRecord_userId_fkey")
  @@index([butterflyId], map: "ButterflyRecord_butterflyId_fkey")
}

model Character {
  id           Int        @id @default(autoincrement())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @default(now()) @updatedAt
  name         String     @db.VarChar(256)
  achievements String?    @db.VarChar(764)
  alignment    String?    @db.VarChar(256)
  experience   Int        @default(0)
  level        Int        @default(1)
  class        String?    @db.VarChar(764)
  species      String?    @db.VarChar(764)
  backstory    String?    @db.Text
  drive        String?    @db.VarChar(764)
  quirks       String?    @db.Text
  genre        String?    @db.VarChar(256)
  artImageId   Int?
  isPublic     Boolean    @default(true)
  userId       Int        @default(10)
  artPrompt    String?    @db.Text
  honorific    String?    @default("adventurer") @db.VarChar(256)
  imagePath    String?    @db.VarChar(764)
  designer     String?    @db.VarChar(256)
  personality  String?    @db.Text
  isMature     Boolean    @default(false)
  isActive     Boolean    @default(true)
  charm        Rarity     @default(COMMON)
  empathy      Rarity     @default(COMMON)
  grace        Rarity     @default(COMMON)
  luck         Rarity     @default(COMMON)
  might        Rarity     @default(COMMON)
  presentation String?    @db.VarChar(764)
  role         String?    @db.VarChar(256)
  title        String?    @db.VarChar(256)
  wits         Rarity     @default(COMMON)
  gender       String?    @db.VarChar(256)
  ArtImage     ArtImage?  @relation(fields: [artImageId], references: [id])
  User         User       @relation(fields: [userId], references: [id])
  Chats        Chat[]
  Reactions    Reaction[]
  Dreams       Dream[]    @relation("CharacterToDream")
  Rewards      Reward[]   @relation("CharacterToReward")
  Scenarios    Scenario[] @relation("CharacterToScenario")
  Compositions  Composition[]

  @@index([userId], map: "Character_userId_fkey")
  @@index([isPublic])
  @@index([isActive])
  @@index([name])
  @@index([artImageId], map: "Character_artImageId_fkey")
}

/// a chat can be between users, user to Bot or Character, on to a Forum or Channel (aka chatroom)
/// originId should always be shared in subsequent messages so we can track the thread via originID and createdAt
/// splitting the chat into a new thread creates a fresh originId
model Chat {
  id              Int        @id @default(autoincrement())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime?  @default(now()) @updatedAt
  type            ChatType
  sender          String     @db.VarChar(255)
  recipient       String?    @db.VarChar(255)
  content         String     @db.Text
  title           String?    @db.VarChar(255)
  isPublic        Boolean    @default(true)
  isFavorite      Boolean    @default(false)
  previousEntryId Int?
  originId        Int?
  userId          Int?
  botId           Int?
  recipientId     Int?
  artImageId      Int?
  promptId        Int?
  botName         String?    @db.VarChar(255)
  channel         String?    @db.VarChar(255)
  botResponse     String?
  characterId     Int?
  isRead          Boolean    @default(false)
  isMature        Boolean    @default(false)
  serverId        Int?
  serverName      String?    @db.VarChar(256)
  dreamId         Int?
  isActive        Boolean    @default(true)
  ArtImage        ArtImage?  @relation(fields: [artImageId], references: [id])
  Bot             Bot?       @relation(fields: [botId], references: [id])
  Character       Character? @relation(fields: [characterId], references: [id])
  Dream           Dream?     @relation(fields: [dreamId], references: [id])
  Prompt          Prompt?    @relation(fields: [promptId], references: [id])
  Server          Server?    @relation(fields: [serverId], references: [id])
  User            User?      @relation(fields: [userId], references: [id])
  Reactions       Reaction[]

  @@index([serverId], map: "Chat_serverId_fkey")
  @@index([botId], map: "Chat_botId_fkey")
  @@index([characterId], map: "Chat_characterId_fkey")
  @@index([promptId], map: "Chat_promptId_fkey")
  @@index([userId], map: "Chat_userId_fkey")
  @@index([dreamId], map: "Chat_dreamId_fkey")
  @@index([artImageId], map: "Chat_artImageId_fkey")
}

/// programmatic blueprints to call one or more art or text servers
model Code {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  userId      Int      @default(10)
  title       String
  description String?  @db.Text
  icon        String?
  graph       Json
  isPublic    Boolean  @default(false)
  isOfficial  Boolean  @default(false)
  isActive    Boolean  @default(true)
  isMature    Boolean  @default(false)
  User        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isPublic])
  @@index([isOfficial])
  @@index([isActive])
  @@index([isMature])
}

/// Components track all the components we use making kindrobots. it's primary uses are as a museum of developmental attemps, while allowing reactions to allow sifting concepts and allowing the best to rise to attention.
model Component {
  id                Int        @id @default(autoincrement())
  createdAt         DateTime   @default(now())
  updatedAt         DateTime?  @default(now()) @updatedAt
  folderName        String
  componentName     String     @unique
  isWorking         Boolean    @default(true)
  underConstruction Boolean    @default(false)
  isBroken          Boolean    @default(false)
  title             String?
  notes             String?
  artImageId        Int?
  ArtImage          ArtImage?  @relation(fields: [artImageId], references: [id])
  Reactions         Reaction[]

  @@index([artImageId], map: "Component_artImageId_fkey")
}



model Composition {
id          Int      @id @default(autoincrement())
createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt
// Core fields
title       String   @db.VarChar(255)
description String?  @db.VarChar(512)
label       String?  @db.VarChar(255)
// What to generate
mode        String   @default("both") @db.VarChar(64)
// 'narrative' | 'art' | 'both'
// Flags
isPublic    Boolean  @default(true)
isMature    Boolean  @default(false)
isActive    Boolean  @default(true)
designer    String?  @default("system") @db.VarChar(255)
// ── Ingredient FKs (all optional) ─────────────────────────────────────────
characterId Int?
dreamId     Int?
scenarioId  Int?
pitchId     Int?
rewardId    Int?
// ── Freeform overrides (used when no FK is set, or to override) ───────────
characterBlurb  String? @db.VarChar(512)
dreamBlurb      String? @db.VarChar(512)
scenarioBlurb   String? @db.VarChar(512)
pitchBlurb      String? @db.VarChar(512)
rewardBlurb     String? @db.VarChar(512)
// ── Outputs ───────────────────────────────────────────────────────────────
narrativeText String? @db.Text
artPrompt     String? @db.Text
// ── Relations ─────────────────────────────────────────────────────────────
userId    Int?
User      User?      @relation(fields: [userId], references: [id])
artImageId Int?      @unique
ArtImage   ArtImage? @relation(fields: [artImageId], references: [id])
Character  Character? @relation(fields: [characterId], references: [id])
Dream      Dream?     @relation(fields: [dreamId], references: [id])
Scenario   Scenario?  @relation(fields: [scenarioId], references: [id])
Pitch      Pitch?     @relation(fields: [pitchId], references: [id])
Reward     Reward?    @relation(fields: [rewardId], references: [id])
Reactions  Reaction[]
@@index([userId])
@@index([mode])
@@index([characterId])
@@index([dreamId])
@@index([scenarioId])
@@index([pitchId])
@@index([rewardId])
}

model Dream {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @default(now()) @updatedAt
  title           String          @db.VarChar(255)
  slug            String?         @unique @db.VarChar(255)
  description     String?         @db.Text
  currentVibe     String?         @db.Text
  currentPrompt   String?         @db.Text
  userId          Int             @default(10)
  pitchId         Int?
  artImageId      Int?
  textServerId    Int?
  artServerId     Int?
  artCollectionId Int?
  scenarioId      Int?
  isPublic        Boolean         @default(true)
  isMature        Boolean         @default(false)
  isActive        Boolean         @default(true)
  accessMode      DreamAccessMode @default(OPEN)
  privacyCode     String?         @db.VarChar(255)
  artPrompt       String?         @db.Text
  Chats           Chat[]
  ArtCollection   ArtCollection?  @relation(fields: [artCollectionId], references: [id])
  ArtImage        ArtImage?       @relation(fields: [artImageId], references: [id])
  Pitch           Pitch?          @relation(fields: [pitchId], references: [id])
  Scenario        Scenario?       @relation(fields: [scenarioId], references: [id])
  User            User            @relation(fields: [userId], references: [id])
  Reactions       Reaction[]
  Characters      Character[]     @relation("CharacterToDream")
  Rewards         Reward[]        @relation("DreamToReward")
  Compositions  Composition[]

  @@index([artImageId], map: "Dream_artImageId_fkey")
  @@index([userId])
  @@index([accessMode])
  @@index([isPublic])
  @@index([isActive])
  @@index([artCollectionId])
  @@index([pitchId])
  @@index([scenarioId])
}

/// our woefully underutilized log function, but it's there.
model Log {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  timestamp DateTime @db.DateTime(0)
  username  String?  @db.VarChar(764)
  userId    Int?
  User      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "Log_userId_fkey")
}

/// website achievements! This holds the milestones that can be achieved (in the flavor text we refer to them as "jellybeans"). They are not user editable and set by myself. only about 1/3 are currently utilized, and one of my biggest todos before public release.
model Milestone {
  id               Int               @id @default(autoincrement())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime?         @default(now()) @updatedAt
  label            String            @db.VarChar(764)
  message          String            @db.VarChar(764)
  icon             String?           @db.VarChar(764)
  karma            Int               @default(0)
  pageHint         String?           @db.VarChar(764)
  subtleHint       String?           @db.VarChar(764)
  triggerCode      String?           @db.VarChar(764)
  tooltip          String?           @db.VarChar(764)
  isActive         Boolean           @default(false)
  isRepeatable     Boolean           @default(true)
  artImageId       Int?
  artPrompt        String?           @db.Text
  ArtImage         ArtImage?         @relation(fields: [artImageId], references: [id])
  MilestoneRecords MilestoneRecord[]

  @@index([artImageId], map: "Milestone_artImageId_fkey")
}

/// the records of milestones earned. They record the date, username, id, etc. Users are given the option to clear their milestones so they can hunt fresh. I use this extensively in debugging.
model MilestoneRecord {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  username    String?   @db.VarChar(764)
  milestoneId Int
  userId      Int
  isConfirmed Boolean   @default(false)
  Milestones  Milestone @relation(fields: [milestoneId], references: [id])
  User        User      @relation(fields: [userId], references: [id])

  @@index([milestoneId], map: "MilestoneRecord_milestoneId_fkey")
  @@index([userId], map: "MilestoneRecord_userId_fkey")
}

/// A Pitch is a big picture tag system that is meant to be fuel for a project that can become art assets, text assets, and physical swag. It can be parents, siblings, or children with other pitches.
model Pitch {
  id             Int            @id @default(autoincrement())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime?      @default(now()) @updatedAt
  title          String?        @db.VarChar(256)
  pitch          String         @db.VarChar(764)
  designer       String?        @db.VarChar(256)
  flavorText     String?        @db.VarChar(512)
  highlightImage String?        @db.VarChar(256)
  PitchType      PitchType      @default(ARTPITCH)
  isMature       Boolean        @default(false)
  isPublic       Boolean        @default(true)
  userId         Int?           @default(1)
  description    String?        @db.VarChar(256)
  artImageId     Int?
  examples       String?        @db.LongText
  icon           String?
  creationSource CreationSource @default(HUMAN)
  isActive       Boolean        @default(true)
  artPrompt      String?        @db.Text
  Dreams          Dream[]
  ArtImage       ArtImage?      @relation(fields: [artImageId], references: [id])
  User           User?          @relation(fields: [userId], references: [id])
  Prompt         Prompt[]
  Reactions      Reaction[]
  Compositions  Composition[]

  @@index([userId], map: "Pitch_userId_fkey")
  @@index([artImageId], map: "Pitch_artImageId_fkey")
}

/// this is an art or text prompt to an ai to generate new media
model Prompt {
  id             Int            @id @default(autoincrement())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime?      @default(now()) @updatedAt
  prompt         String         @db.Text
  userId         Int?           @default(1)
  pitchId        Int?
  botId          Int?
  artImageId     Int?
  creationSource CreationSource @default(HUMAN)
  isMature       Boolean        @default(false)
  isPublic       Boolean        @default(true)
  isActive       Boolean        @default(true)
  artPrompt      String?        @db.Text
  Chats          Chat[]
  ArtImage       ArtImage?      @relation(fields: [artImageId], references: [id])
  Bot            Bot?           @relation(fields: [botId], references: [id])
  Pitch          Pitch?         @relation(fields: [pitchId], references: [id])
  User           User?          @relation(fields: [userId], references: [id])
  Reactions      Reaction[]

  @@index([userId], map: "Prompt_userId_fkey")
  @@index([artImageId], map: "Prompt_artImageId_fkey")
  @@index([botId], map: "Prompt_botId_fkey")
  @@index([pitchId], map: "Prompt_pitchId_fkey")
}

model Reaction {
  id               Int                       @id @unique @default(autoincrement())
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime?                 @default(now()) @updatedAt
  comment          String?                   @db.Text
  userId           Int
  pitchId          Int?
  componentId      Int?
  reactionType     ReactionType
  reactionCategory Reaction_reactionCategory @default(ART_IMAGE)
  rating           Int                       @default(0)
  artImageId       Int?
  botId            Int?
  promptId         Int?
  resourceId       Int?
  rewardId         Int?
  chatId           Int?
  dreamId          Int?
  artCollectionId  Int?
  butterflyId      Int?
  characterId      Int?
  scenarioId       Int?
  themeId          Int?
  compositionId    Int?
  ArtCollection    ArtCollection?            @relation(fields: [artCollectionId], references: [id])
  ArtImage         ArtImage?                 @relation(fields: [artImageId], references: [id])
  Bot              Bot?                      @relation(fields: [botId], references: [id])
  Butterfly        Butterfly?                @relation(fields: [butterflyId], references: [id])
  Character        Character?                @relation(fields: [characterId], references: [id])
  Chat             Chat?                     @relation(fields: [chatId], references: [id])
  Component        Component?                @relation(fields: [componentId], references: [id])
  Composition      Composition?              @relation(fields: [compositionId], references: [id])
  Dream            Dream?                    @relation(fields: [dreamId], references: [id])
  Pitch            Pitch?                    @relation(fields: [pitchId], references: [id])
  Prompt           Prompt?                   @relation(fields: [promptId], references: [id])
  Resource         Resource?                 @relation(fields: [resourceId], references: [id])
  Reward           Reward?                   @relation(fields: [rewardId], references: [id])
  Scenario         Scenario?                 @relation(fields: [scenarioId], references: [id])
  Theme            Theme?                    @relation(fields: [themeId], references: [id])
  User             User                      @relation(fields: [userId], references: [id])


  @@index([userId], map: "Reaction_userId_fkey")
  @@index([artImageId], map: "Reaction_artImageId_fkey")
  @@index([artCollectionId], map: "Reaction_artCollectionId_fkey")
  @@index([botId], map: "Reaction_botId_fkey")
  @@index([butterflyId], map: "Reaction_butterflyId_fkey")
  @@index([characterId], map: "Reaction_characterId_fkey")
  @@index([chatId], map: "Reaction_chatId_fkey")
  @@index([componentId], map: "Reaction_componentId_fkey")
  @@index([dreamId], map: "Reaction_dreamId_fkey")
  @@index([pitchId], map: "Reaction_pitchId_fkey")
  @@index([promptId], map: "Reaction_promptId_fkey")
  @@index([resourceId], map: "Reaction_resourceId_fkey")
  @@index([rewardId], map: "Reaction_rewardId_fkey")
  @@index([scenarioId], map: "Reaction_scenarioId_fkey")
  @@index([themeId], map: "Reaction_themeId_fkey")
  @@index([compositionId])
}

/// This should also be used if a user wants to add a custom art or text checkpoints
model Resource {
  id              Int             @id @default(autoincrement())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime?       @default(now()) @updatedAt
  name            String          @unique(map: "Resource_id_key", length: 200) @db.VarChar(764)
  customLabel     String?         @db.VarChar(764)
  MediaPath       String?         @db.VarChar(764)
  customUrl       String?         @db.VarChar(764)
  civitaiUrl      String?         @db.VarChar(764)
  huggingUrl      String?         @db.VarChar(764)
  localPath       String?         @db.VarChar(764)
  description     String?         @db.Text
  isMature        Boolean         @default(false)
  resourceType    ResourceType    @default(EMBEDDING)
  userId          Int?            @default(1)
  artImageId      Int?
  imagePath       String?
  generation      String?
  supportedServer SupportedServer @default(SDXL)
  isPublic        Boolean         @default(false)
  isActive        Boolean         @default(true)
  artPrompt       String?         @db.Text
  ArtImages       ArtImage[]      @relation("ArtImageCheckpointResource")
  UsedInImages     ArtImage[]  @relation("ArtImageLoraResources")
  Reactions       Reaction[]
  ArtImage        ArtImage?       @relation("ResourcePreviewImage", fields: [artImageId], references: [id])
  User            User?           @relation(fields: [userId], references: [id])
  Servers         Server[]        @relation("ResourceToServer")

  @@index([userId], map: "Resource_userId_fkey")
  @@index([artImageId], map: "Resource_artImageId_fkey")
}

model Reward {
  id         Int         @id @default(autoincrement())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime?   @default(now()) @updatedAt
  icon       String?     @db.VarChar(256)
  text       String      @db.Text
  power      String      @db.Text
  collection String?     @db.VarChar(764)
  rarity     Rarity      @default(COMMON)
  label      String?     @db.VarChar(764)
  userId     Int?        @default(1)
  artImageId Int?
  imagePath  String?     @db.VarChar(764)
  isMature   Boolean     @default(false)
  isPublic   Boolean     @default(true)
  isActive   Boolean     @default(true)
  artPrompt  String?     @db.Text
  rewardType RewardType  @default(ITEM)
  Reactions  Reaction[]
  ArtImage   ArtImage?   @relation(fields: [artImageId], references: [id])
  User       User?       @relation(fields: [userId], references: [id])
  Characters Character[] @relation("CharacterToReward")
  Dreams     Dream[]     @relation("DreamToReward")
  Compositions  Composition[]

  @@index([userId], map: "Reward_userId_fkey")
  @@index([rewardType])
  @@index([rarity])
  @@index([artImageId], map: "Reward_artImageId_fkey")
}

/// Scenarios are meant to be chatroom settings or storytelling scenarios that incorporate other elements like Character, prompt, ArtImage, etc. A user is given options to continue the scenario with a skill check, inventory item, Reward, or custom prompt. The idea is to generate a story through the back and forth exchange.
model Scenario {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime?   @default(now()) @updatedAt
  title        String
  description  String      @db.Text
  intros       String      @db.Text
  userId       Int
  artImageId   Int?
  imagePath    String?
  locations    String?     @db.Text
  artPrompt    String?     @db.Text
  genres       String?
  inspirations String?     @db.Text
  isMature     Boolean     @default(false)
  isPublic     Boolean     @default(true)
  isActive     Boolean     @default(true)
  Dream        Dream[]
  Reactions    Reaction[]
  ArtImage     ArtImage?   @relation(fields: [artImageId], references: [id])
  User         User        @relation(fields: [userId], references: [id])
  Characters   Character[] @relation("CharacterToScenario")
  Compositions  Composition[]

  @@index([artImageId], map: "Scenario_artImageId_fkey")
  @@index([userId], map: "Scenario_userId_fkey")
}

model Server {
  id                         Int                    @id @default(autoincrement())
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  title                      String
  label                      String?
  description                String?
  serverType                 ServerType             @default(ART)
  category                   String?
  baseUrl                    String
  endpointPath               String?
  healthPath                 String?
  userId                     Int?
  isPublic                   Boolean                @default(true)
  isOfficial                 Boolean                @default(false)
  isDefault                  Boolean                @default(false)
  isActive                   Boolean                @default(true)
  isEditable                 Boolean                @default(true)
  requiresApiKey             Boolean                @default(false)
  apiKeyName                 String?
  supportsTxt2Img            Boolean                @default(false)
  supportsImg2Img            Boolean                @default(false)
  supportsChat               Boolean                @default(false)
  supportsComfyWorkflow      Boolean                @default(false)
  supportsCheckpointOverride Boolean                @default(false)
  supportsSampler            Boolean                @default(false)
  supportsNegativePrompt     Boolean                @default(false)
  supportsSeed               Boolean                @default(false)
  supportsSteps              Boolean                @default(false)
  supportsVideo              Boolean                @default(false)
  apiLink                    String?
  model                      String?
  apiKey                     String?                @db.Text
  designer                   String?
  version                    String?
  notes                      String?
  sortOrder                  Int                    @default(0)
  lastCheckedAt              DateTime?
  lastStatus                 ServerStatus?
  oidcProvider               String?
  useOidc                    Boolean                @default(false)
  accessMode                 ServerAccessMode       @default(LOCAL)
  allowBrowserRequests       Boolean                @default(true)
  isPrivateNetwork           Boolean                @default(false)
  requiresClientSideCheck    Boolean                @default(false)
  backendBaseUrl             String?
  browserBaseUrl             String?
  defaultCfg                 Float?
  defaultHeight              Int                    @default(512)
  defaultSampler             String?
  defaultScheduler           String?
  defaultSteps               Int?
  defaultTransport           ServerTransport        @default(BROWSER)
  defaultWidth               Int                    @default(512)
  generationEngine           ServerGenerationEngine @default(A1111)
  supportsBatch              Boolean                @default(false)
  supportsFlux               Boolean                @default(false)
  supportsImageEdit          Boolean                @default(false)
  supportsInpaint            Boolean                @default(false)
  supportsKontext            Boolean                @default(false)
  supportsOutpaint           Boolean                @default(false)
  supportsWorkflowUpload     Boolean                @default(false)
  workflowJson               String?                @db.LongText
  workflowPath               String?
  workflowVersion            String?
  isMature                   Boolean                @default(false)
  artPrompt                  String?                @db.Text
  ArtImages                  ArtImage[]             @relation("ArtImageGeneratorServer")
  Bots                       Bot[]
  Chats                      Chat[]
  user                       User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Resources                  Resource[]             @relation("ResourceToServer")

  @@index([serverType])
  @@index([isPublic])
  @@index([userId])
  @@index([accessMode])
}

/// Smart Icons are used internally to generate the user's icon array. They can create custom icons that are links to pages or commands
model SmartIcon {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @default(now()) @updatedAt
  title       String    @db.VarChar(255)
  type        String    @db.VarChar(255)
  designer    String?   @db.VarChar(255)
  userId      Int?      @default(10)
  icon        String?   @db.VarChar(255)
  label       String?   @db.VarChar(255)
  link        String?   @db.VarChar(512)
  component   String?   @db.VarChar(255)
  isPublic    Boolean   @default(true)
  description String?   @db.VarChar(255)
  category    String?   @db.VarChar(255)
  modelType   String?   @db.VarChar(255)
  isMature    Boolean   @default(false)
  User        User?     @relation(fields: [userId], references: [id])

  @@index([userId], map: "SmartIcon_userId_fkey")
}

model Theme {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  values      String     @db.LongText
  userId      Int?
  isPublic    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  tagline     String?
  room        String?
  colorScheme String     @default("light")
  prefersDark Boolean    @default(false)
  isActive    Boolean    @default(true)
  artPrompt   String?    @db.Text
  Reactions   Reaction[]
  user        User?      @relation(fields: [userId], references: [id])

  @@index([userId], map: "Theme_userId_fkey")
}

