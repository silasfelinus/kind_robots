POST {{baseUrl}}/api/dreams
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Conductor App",
  "slug": "conductor-app",
  "dreamType": "PROJECT",
  "projectStatus": "BRAINSTORM",
  "description": "Flutter mobile/desktop app for the Conductor system. Login via kind_robots JWT. Dashboard: active projects, open todos, agent status. Create todos on the go, receive push notifications for blocked tasks and PR reviews, request art from phone camera, quick voice-to-todo.",
  "pitch": "Conductor in your pocket — log a todo on a walk, approve a PR from the couch.",
