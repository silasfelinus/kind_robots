### Seed: All Conductor Projects as one batch
@base = https://kind-robots.vercel.app/api
@admintoken = {{$dotenv ADMIN_TOKEN}}
@imgbase = https://raw.githubusercontent.com/silasfelinus/conductor/main/projects/images

POST {{base}}/dreams/batch
Content-Type: application/json
x-admin-token: {{admintoken}}

{
  "dreams": [
    {
      "title": "Kind Robots",
